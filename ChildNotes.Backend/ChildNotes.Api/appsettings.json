{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=127.0.0.1;Port=3306;Database=child_notes;Uid=root;Pwd=;"
  },
  "Jwt": {
    "Secret": "change-this-jwt-secret-before-deploy-at-least-32-chars",
    "ExpireDays": 30
  },
  "DeepSeek": {
    "BaseUrl": "https://api.deepseek.com",
    "ApiKey": "",
    "Model": "deepseek-chat",
    "Temperature": 0.3,
    "MaxTokens": 2500,
    "ThinkingEnabled": false,
    "ReasoningEffort": "high"
  },
  "Oss": {
    "Endpoint": "",
    "AccessKeyId": "",
    "AccessKeySecret": "",
    "BucketName": "",
    "BaseUrl": ""
  },
  "RateLimit": {
    "Enabled": true,
    "MaxRequestsPerSecond": 5,
    "BlacklistRequestsPerSecond": 10,
    "TrustProxyHeaders": true
  },
  "Upload": {
    "LocalRoot": "uploads",
    "LocalBaseUrl": "/uploads",
    "MaxFileSizeBytes": 20971520
  },
  "Admin": {
    "InitUsername": "admin",
    "InitPassword": "change-this-admin-password",
    "InitDisplayName": "Administrator",
    "TokenExpireHours": 12
  }
}
