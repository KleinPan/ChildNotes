# 默认自动换行处理
* text=auto

# shell 脚本强制 LF (Linux 部署脚本 CRLF 会导致 bash 解析失败)
*.sh text eol=lf

# systemd unit / Caddyfile 等也用 LF
*.service text eol=lf
Caddyfile text eol=lf

# Windows 批处理用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.ttc binary
*.apk binary
*.zip binary
*.tar.gz binary
*.xdb binary
