<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  
  <ItemGroup>
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="AvaloniaUI.DiagnosticsSupport">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="Keincheck">
      <!-- Keincheck 依赖 ASP.NET Core（MCP HTTP server），Android/iOS 无对应 runtime pack。
           仅在桌面端 Debug 配置下引入（Keincheck 仅用于 Windows 桌面 MCP 调试）。
           Android/iOS 即使 Debug 也必须排除，否则还原时找不到 android-arm64 的 AspNetCore runtime pack。 -->
      <IncludeAssets Condition="'$(Configuration)' != 'Debug' OR ('$(RuntimeIdentifier)' != '' AND ($(RuntimeIdentifier.StartsWith('android')) OR $(RuntimeIdentifier.StartsWith('ios'))))">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug' OR ('$(RuntimeIdentifier)' != '' AND ($(RuntimeIdentifier.StartsWith('android')) OR $(RuntimeIdentifier.StartsWith('ios'))))">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Data.Sqlite" />
    <PackageReference Include="Semi.Avalonia" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\ChildNotes.Shared\ChildNotes.Shared.csproj" />
  </ItemGroup>
</Project>
