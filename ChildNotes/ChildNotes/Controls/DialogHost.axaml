<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ChildNotes.Controls"
             x:Class="ChildNotes.Controls.DialogHost"
             x:DataType="controls:DialogHost">
    <Panel IsVisible="{Binding IsOpen, RelativeSource={RelativeSource AncestorType=controls:DialogHost}}">
        <Border Classes="modal-mask"/>
        <Border Background="White" CornerRadius="12" Padding="24,20"
                MaxWidth="300" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=controls:DialogHost}}"
                           FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                <ContentControl Content="{Binding MessageContent, RelativeSource={RelativeSource AncestorType=controls:DialogHost}}"/>
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <Button Content="{Binding CancelText, RelativeSource={RelativeSource AncestorType=controls:DialogHost}}"
                            Classes="weui-btn default" CornerRadius="24" MinWidth="100" MinHeight="40"
                            Command="{Binding CancelCommand, RelativeSource={RelativeSource AncestorType=controls:DialogHost}}"/>
                    <Button Content="{Binding ConfirmText, RelativeSource={RelativeSource AncestorType=controls:DialogHost}}"
                            Classes="weui-btn warn" CornerRadius="24" MinWidth="100" MinHeight="40"
                            Command="{Binding ConfirmCommand, RelativeSource={RelativeSource AncestorType=controls:DialogHost}}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
