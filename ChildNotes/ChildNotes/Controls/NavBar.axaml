<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ChildNotes.Controls"
             x:Class="ChildNotes.Controls.NavBar"
             x:DataType="controls:NavBar">
    <Border Classes="nav-bar">
        <Grid ColumnDefinitions="Auto,*,Auto">
            <!-- 左侧：返回按钮（可隐藏）。命令绑定到外部 DataContext 的 BackCommand（用 ReflectionBinding 跳过编译期类型校验） -->
            <Button Grid.Column="0" Classes="nav-back"
                    Command="{ReflectionBinding BackCommand}"
                    IsVisible="{Binding ShowBack, RelativeSource={RelativeSource AncestorType=controls:NavBar}}"
                    Click="OnBackClick"/>

            <!-- 中间：标题 -->
            <TextBlock Grid.Column="1" Classes="nav-title"
                       Text="{Binding Title, RelativeSource={RelativeSource AncestorType=controls:NavBar}}"/>

            <!-- 右侧：自定义内容（按钮、文本等） -->
            <ContentControl Grid.Column="2"
                            Content="{Binding RightContent, RelativeSource={RelativeSource AncestorType=controls:NavBar}}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
