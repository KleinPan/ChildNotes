<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="using:ChildNotes.Infrastructure"
             x:Class="ChildNotes.Controls.DevLogOverlay"
             IsVisible="True">
    <!-- 浮层容器：固定在右上角，可折叠 -->
    <Grid>
        <!-- 折叠态：小图标按钮 -->
        <Button x:Name="ToggleButton"
                Click="OnToggle"
                Content="LOG"
                FontSize="10"
                Padding="6,3"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Background="#EE0333"
                Foreground="White"
                CornerRadius="4"
                ZIndex="1000"
                IsVisible="True"/>

        <!-- 展开态：半透明日志面板 -->
        <Border x:Name="Panel"
                IsVisible="False"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="4"
                Background="#F0222222"
                CornerRadius="6"
                ZIndex="1001">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- 顶部工具栏 -->
                <Border Grid.Row="0" Background="#33000000" Padding="8,4" CornerRadius="6,6,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="DEV LOG" Foreground="#0FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="清" Click="OnClear" Padding="6,2" FontSize="10" Margin="4,0" Background="#333" Foreground="White"/>
                        <Button Grid.Column="2" Content="底" Click="OnScrollEnd" Padding="6,2" FontSize="10" Margin="4,0" Background="#333" Foreground="White"/>
                        <Button Grid.Column="3" Content="×" Click="OnToggle" Padding="6,2" FontSize="10" Background="#333" Foreground="White"/>
                    </Grid>
                </Border>

                <!-- 日志列表 -->
                <ScrollViewer Grid.Row="1" x:Name="LogScroll" Background="#10000000" Padding="4">
                    <ItemsControl x:Name="LogList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="infra:DevLogger+LogEntry">
                                <TextBlock Text="{Binding Full}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="10"
                                           Foreground="#DDD" TextWrapping="Wrap" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 底部状态 -->
                <Border Grid.Row="2" Background="#33000000" Padding="8,2" CornerRadius="0,0,6,6">
                    <TextBlock x:Name="StatusText" Foreground="#888" FontSize="9"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
