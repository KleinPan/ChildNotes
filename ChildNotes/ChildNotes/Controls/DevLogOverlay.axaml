<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="using:ChildNotes.Infrastructure"
             x:Class="ChildNotes.Controls.DevLogOverlay"
             IsVisible="True">
    <!-- 浮层容器：固定在右上角，可折叠 -->
    <Grid>
        <!-- 折叠态：小图标按钮 -->
        <Button x:Name="ToggleButton"
                Click="OnToggle"
                Content="LOG"
                FontSize="10"
                Padding="6,3"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Background="#EE0333"
                Foreground="White"
                CornerRadius="4"
                ZIndex="1000"
                IsVisible="True"/>

        <!-- 展开态：半透明日志面板 -->
        <Border x:Name="Panel"
                IsVisible="False"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="4"
                Background="#F0222222"
                CornerRadius="6"
                ZIndex="1001">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- 顶部工具栏 -->
                <Border Grid.Row="0" Background="#33000000" Padding="8,4" CornerRadius="6,6,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="DEV LOG（可跨行选择/Ctrl+A 全选）" Foreground="#0FF" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="全选" Click="OnSelectAll" Padding="6,2" FontSize="10" Margin="4,0" Background="#333" Foreground="White"/>
                        <Button Grid.Column="2" Content="清" Click="OnClear" Padding="6,2" FontSize="10" Margin="4,0" Background="#333" Foreground="White"/>
                        <Button Grid.Column="3" Content="底" Click="OnScrollEnd" Padding="6,2" FontSize="10" Margin="4,0" Background="#333" Foreground="White"/>
                        <Button Grid.Column="4" Content="×" Click="OnToggle" Padding="6,2" FontSize="10" Background="#333" Foreground="White"/>
                    </Grid>
                </Border>

                <!-- 日志内容：单一 SelectableTextBlock 承载全部日志，支持跨行选择与全选 -->
                <ScrollViewer Grid.Row="1" x:Name="LogScroll" Background="#10000000" Padding="4">
                    <SelectableTextBlock x:Name="LogText"
                                         FontFamily="Cascadia Code,Consolas,monospace"
                                         FontSize="10"
                                         Foreground="#DDD"
                                         TextWrapping="Wrap"/>
                </ScrollViewer>

                <!-- 底部状态 -->
                <Border Grid.Row="2" Background="#33000000" Padding="8,2" CornerRadius="0,0,6,6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" x:Name="StatusText" Foreground="#888" FontSize="9"/>
                        <TextBlock Grid.Column="1" x:Name="PlatformText" Foreground="#0F0" FontSize="9" FontWeight="Bold"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
