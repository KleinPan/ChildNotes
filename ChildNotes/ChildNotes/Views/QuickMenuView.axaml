<UserControl x:Class="ChildNotes.Views.QuickMenuView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:m="using:ChildNotes.Models.Home"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="180"
             d:DesignWidth="390"
             x:DataType="vm:QuickMenuViewModel"
             Background="{StaticResource WeuiBg2Brush}"
             mc:Ignorable="d">

    <UserControl.Styles>
        <!-- 功能面板项：圆形图标 + 文字标签，对齐微信风格 -->
        <Style Selector="Button.action-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Border.action-icon">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>
        <Style Selector="TextBlock.action-emoji">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.action-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <!-- PipsPager 指示器样式：小圆点紧凑居中 -->
        <Style Selector="PipsPager.pager">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
            <Setter Property="Orientation" Value="Horizontal"/>
        </Style>
    </UserControl.Styles>

    <!-- 功能面板：Carousel 翻页 + PipsPager 页码指示器。
         8 项时 1 页（PipsPager 自动隐藏），>8 项时自动分页。
         无遮罩层，面板直接可交互。 -->
    <Border Padding="16,12" Background="{StaticResource WeuiBg2Brush}"
            BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
            IsVisible="{Binding IsMenuOpen}">
        <StackPanel Spacing="0">
            <!-- Carousel：每页一个 UniformGrid 4×2，支持左右滑动 -->
            <!-- IsSwipeEnabled 启用触摸与鼠标滑动手势切换页面（对齐微信风格） -->
            <Carousel ItemsSource="{Binding Pages}"
                      SelectedIndex="{Binding CurrentPage, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      IsSwipeEnabled="True"
                      IsTabStop="False">
                <Carousel.ItemTemplate>
                    <!-- Carousel 每个 Item 是 List<QuickActionItem>（一页数据），
                         用 ItemsControl 嵌套渲染单页内的 8 个功能按钮。 -->
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" Rows="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:QuickActionItem">
                                    <Button Classes="action-item"
                                            Command="{Binding $parent[UserControl].((vm:QuickMenuViewModel)DataContext).SelectCommand}"
                                            CommandParameter="{Binding Type}">
                                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                                            <Border Classes="action-icon" Background="{Binding IconBg}">
                                                <TextBlock Classes="action-emoji" Text="{Binding Icon}"/>
                                            </Border>
                                            <TextBlock Classes="action-label" Text="{Binding Label}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </Carousel.ItemTemplate>
            </Carousel>

            <!-- PipsPager 页码指示器（>1 页时显示） -->
            <PipsPager Classes="pager"
                       NumberOfPages="{Binding PageCount}"
                       SelectedPageIndex="{Binding CurrentPage, Mode=TwoWay}"
                       IsVisible="{Binding HasMultiplePages}"/>
        </StackPanel>
    </Border>
</UserControl>
