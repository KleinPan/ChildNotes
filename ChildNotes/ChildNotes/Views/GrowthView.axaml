<UserControl x:Class="ChildNotes.Views.GrowthView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:ChildNotes.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:v="using:ChildNotes.Views"
             xmlns:vm="using:ChildNotes.ViewModels"
             d:DesignHeight="844"
             d:DesignWidth="390"
             x:DataType="vm:GrowthViewModel"
             x:CompileBindings="True"
             mc:Ignorable="d">

    <UserControl.Styles>
        <!--  日记卡片：成长记录条目（冷调灰绿色系，与暖橘色时间轴形成视觉层次）  -->
        <Style Selector="Border.growth-card">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="BorderBrush" Value="#7E9B8E" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BoxShadow" Value="0 2 10 0 #0A000000" />
        </Style>
        <Style Selector="Border.growth-card-add">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="BorderBrush" Value="#DDDDDD" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
        <!--  标题：深棕黑、15px SemiBold，视觉权重最高  -->
        <Style Selector="TextBlock.growth-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2D1810" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!--  日期徽章：橘粉色背景白字（与左侧时间轴同色系，呼应时间轴主题）  -->
        <Style Selector="Border.growth-date-badge">
            <Setter Property="Background" Value="#FFCC80" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.growth-date">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <!--  正文：浅棕灰、13px Regular，与标题形成层级差异  -->
        <Style Selector="TextBlock.growth-content">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Regular" />
            <Setter Property="Foreground" Value="#6D4C41" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <!--  时间轴圆点：暖橘色系  -->
        <Style Selector="Border.timeline-dot">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="#FFAB91" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="BoxShadow" Value="0 1 4 0 #20000000" />
        </Style>
        <Style Selector="Border.timeline-dot-add">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CCC" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <!--  照片删除按钮：圆形半透明黑底白字（对齐小程序 .g-photo-del）。
              覆盖 Button 默认主题，避免出现边框/默认背景。  -->
        <Style Selector="Button.photo-del-btn">
            <Setter Property="Background" Value="#80000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.photo-del-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#A0000000" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.photo-del-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#CC000000" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!--  照片添加按钮：虚线边框浅灰底（对齐小程序 .g-photo-add）  -->
        <Style Selector="Button.photo-add-btn">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.photo-add-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="BorderBrush" Value="#CCC" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Margin="0,40,0,32" HorizontalAlignment="Center">
                    <TextBlock Margin="0,0,0,8" HorizontalAlignment="Center" FontSize="40" Text="📆" />
                    <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="#5D4037"
                               Text="{DynamicResource Growth_Title}" />
                    <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="12" Foreground="#A1887F"
                               Text="{DynamicResource Growth_Subtitle}" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Milestones}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MilestoneDisplayItem">
                            <Grid Margin="16,0,16,20" ColumnDefinitions="32,*">
                                <ctrl:TimelineAxisItem Grid.Column="0" DotBorderBrush="White" DotBorderThickness="3" DotBrush="#FFAB91"
                                                       DotSize="14" DotTopMargin="10" HalfSpacing="10" LineBrush="#FFAB91"
                                                       LineWidth="2" />
                                <Border Grid.Column="1" Margin="8,0,0,0" Classes="growth-card" PointerPressed="OnMilestoneTap"
                                        Tag="{Binding .}">
                                    <StackPanel Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Classes="growth-title" Text="{Binding Title}" />
                                            <Border Grid.Column="1" Classes="growth-date-badge">
                                                <TextBlock Classes="growth-date" Text="{Binding DateText}" />
                                            </Border>
                                        </Grid>
                                        <Border Padding="10,8" Background="#F5F5F5" CornerRadius="4" IsVisible="{Binding Content, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Classes="growth-content" Text="{Binding Content}" />
                                        </Border>
                                        <!--  照片缩略图网格（最多 4 张，本地路径同步加载，远程 URL 异步加载）  -->
                                        <ItemsControl IsVisible="{Binding HasPhotos}" ItemsSource="{Binding PhotoThumbnails}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:MilestoneThumbItem">
                                                    <Border Width="72" Height="72" Margin="0,0,6,6" Background="#F0F0F0"
                                                            CornerRadius="6" ClipToBounds="True"
                                                            PointerPressed="OnPhotoTap">
                                                        <Image Source="{Binding Bitmap}" Stretch="UniformToFill" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="16,0,16,40" ColumnDefinitions="32,*">
                    <ctrl:TimelineAxisItem Grid.Column="0" DotBorderBrush="#CCC" DotBorderThickness="2" DotBrush="White"
                                           DotSize="14" DotTopMargin="10" HalfSpacing="20" LineBrush="#EEE"
                                           LineWidth="2" />
                    <Border Grid.Column="1" Margin="8,0,0,0" Classes="growth-card-add" PointerPressed="OnAddMilestone">
                        <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="#BBB" Text="{DynamicResource Growth_AddMoment}" />
                    </Border>
                </Grid>

                <Border MaxWidth="280" Margin="16,8,16,40" Padding="24,28" HorizontalAlignment="Center"
                        Background="#FFF8F5" CornerRadius="6"
                        IsVisible="{Binding Milestones.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                    <StackPanel HorizontalAlignment="Center" Spacing="10">
                        <TextBlock HorizontalAlignment="Center" FontSize="36" Text="🌱" />
                        <TextBlock HorizontalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="#8D6E63"
                                   Text="{DynamicResource Growth_EmptyTitle}" />
                        <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="#A1887F" Text="{DynamicResource Growth_EmptyHint1}"
                                   TextAlignment="Center" />
                        <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="#A1887F" Text="{DynamicResource Growth_EmptyHint2}"
                                   TextAlignment="Center" />
                        <Button Margin="0,8,0,0" Classes="weui-btn primary" Command="{Binding AddMilestoneCommand}" Content="{DynamicResource Growth_AddNow}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  编辑/新增成长记录的底部弹层  -->
        <Panel x:Name="MilestoneEditPanel" IsVisible="{Binding MilestoneEdit.IsVisible}">
            <Border Classes="modal-mask" />

            <!--  Sheet 弹层  -->
            <Border MaxHeight="720" VerticalAlignment="Bottom" Background="{StaticResource WeuiBg2Brush}" CornerRadius="8,8,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!--  头部（固定）  -->
                    <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"
                                       Text="{Binding MilestoneEdit.SheetTitle}" />
                            <Button Grid.Column="1" Padding="8,2" Background="Transparent" BorderThickness="0"
                                    Command="{Binding MilestoneEdit.CloseCommand}"
                                    Content="✕" FontSize="18" />
                        </Grid>
                    </Border>

                    <!--  表单内容（可滚动）  -->
                    <ScrollViewer Grid.Row="1" MinHeight="300" HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16,16" Spacing="16">
                            <!--
                                日期选择放在最前面：DatePicker 弹出面板向下展开，
                                放在表单顶部可确保展开时有充足空间，不会被底部保存按钮遮挡
                            -->
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Text="{DynamicResource Growth_EditDate}" />
                                <ctrl:DateWheelPicker HorizontalAlignment="Stretch"
                                                      SelectedDate="{Binding MilestoneEdit.RecordDate, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Text="{DynamicResource Growth_EditTitle}" />
                                <TextBox x:Name="MilestoneTitleTextBox" Padding="12,8" Background="#F5F5F5" CornerRadius="6" PlaceholderText="{DynamicResource Growth_EditTitlePlaceholder}"
                                         Text="{Binding MilestoneEdit.Title}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Text="{DynamicResource Growth_EditContentLabel}" />
                                <TextBox Height="100" Padding="12,8" VerticalContentAlignment="Top" AcceptsReturn="True"
                                         Background="#F5F5F5" CornerRadius="6" PlaceholderText="{DynamicResource Growth_EditContentPlaceholder}"
                                         Text="{Binding MilestoneEdit.Content}"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                            <!--  照片编辑区：网格 + 添加按钮，最多 4 张  -->
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Text="{DynamicResource Growth_EditPhotosLabel}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                                               Foreground="{StaticResource WeuiFg2Brush}"
                                               IsVisible="{Binding MilestoneEdit.CanAddPhoto}"
                                               Text="{DynamicResource Growth_EditAddPhotoHint}" />
                                </Grid>
                                <WrapPanel>
                                    <ItemsControl HorizontalAlignment="Left" ItemsSource="{Binding MilestoneEdit.Photos}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MilestonePhotoItem">
                                                <Grid Width="80" Height="80" Margin="0,0,8,8">
                                                    <Border CornerRadius="6" ClipToBounds="True">
                                                        <!--  本地路径直接绑定 Bitmap；远程 URL 用 Image 异步加载  -->
                                                        <Image Source="{Binding Bitmap}" Stretch="UniformToFill" />
                                                    </Border>
                                                    <!--  上传中指示器  -->
                                                    <Border Background="#80000000" CornerRadius="6" IsVisible="{Binding IsUploading}">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="10" Foreground="White" Text="{DynamicResource Growth_Uploading}" />
                                                    </Border>
                                                    <!--  删除按钮（右上角内侧，对齐小程序 top:4rpx right:4rpx）  -->
                                                <Button Width="22" Height="22" Margin="0,3,3,0"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Classes="photo-del-btn"
                                                        Click="OnRemovePhotoClick"
                                                        Tag="{Binding .}"
                                                        Content="✕" FontSize="11" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!--  添加按钮：与照片同处一个 WrapPanel，跟随最后一张照片右侧；达到上限时隐藏  -->
                                    <Button Width="80" Height="80" Margin="0,0,0,8"
                                            Classes="photo-add-btn"
                                            Click="OnAddPhotoClick"
                                            IsVisible="{Binding MilestoneEdit.CanAddPhoto}">
                                        <TextBlock FontSize="28" Foreground="#CCC" Text="+" />
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource WeuiRedBrush}" IsVisible="{Binding MilestoneEdit.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Text="{Binding MilestoneEdit.ErrorMessage}" />
                        </StackPanel>
                    </ScrollViewer>

                    <!--  底部按钮栏（固定）  -->
                    <Border Grid.Row="2" Padding="16,12" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <Button Grid.Column="0" HorizontalAlignment="Stretch" Classes="weui-btn primary"
                                    Command="{Binding MilestoneEdit.SaveCommand}"
                                    Content="{DynamicResource Common_Save}" />
                            <Button Grid.Column="1" Margin="8,0,0,0" Classes="weui-btn warn"
                                    Command="{Binding MilestoneEdit.DeleteCommand}"
                                    Content="{DynamicResource Common_Delete}"
                                    IsVisible="{Binding MilestoneEdit.SheetTitle, Converter={x:Static v:GrowthView.IsEditingConverter}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Panel>

        <!--  全屏图片预览弹窗（点击缩略图触发）  -->
        <Panel IsVisible="{Binding IsPreviewOpen}" Background="#CC000000"
               PointerPressed="OnPreviewBackgroundTap">
            <Grid>
                <Image Source="{Binding PreviewCurrentBitmap}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Stretch="Uniform" Margin="24" />
                <!--  关闭按钮  -->
                <Button Width="44" Height="44" Margin="0,24,24,0"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="#80FFFFFF" BorderThickness="0" CornerRadius="22"
                        Command="{Binding ClosePreviewCommand}"
                        Content="✕" FontSize="18" Foreground="Black" />
                <!--  上一张  -->
                <Button Width="44" Height="44" Margin="24,0"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="#80FFFFFF" BorderThickness="0" CornerRadius="22"
                        Command="{Binding PreviewPrevCommand}"
                        Content="‹" FontSize="24" Foreground="Black" />
                <!--  下一张  -->
                <Button Width="44" Height="44" Margin="24,0"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="#80FFFFFF" BorderThickness="0" CornerRadius="22"
                        Command="{Binding PreviewNextCommand}"
                        Content="›" FontSize="24" Foreground="Black" />
                <!--  计数  -->
                <Border Margin="0,0,0,24" Padding="12,6"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Background="#80000000" CornerRadius="12">
                    <TextBlock Foreground="White" FontSize="13"
                               Text="{Binding PreviewCountText}" />
                </Border>
            </Grid>
        </Panel>

    </Panel>
</UserControl>
