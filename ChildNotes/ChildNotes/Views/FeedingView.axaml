<UserControl x:Class="ChildNotes.Views.FeedingView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ChildNotes.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:v="using:ChildNotes.Views"
             xmlns:vm="using:ChildNotes.ViewModels"
             d:DesignHeight="844"
             d:DesignWidth="390"
             x:CompileBindings="True"
             x:DataType="vm:FeedingViewModel"
             Background="{StaticResource WeuiBg0Brush}"
             mc:Ignorable="d">

    <UserControl.Styles>
        <!--
            日期切换箭头按钮：圆形 36×36，启用态 WeuiGreen(#07C160)，
            禁用态使用设计系统 Text Disabled 色 #BDBDBD，
            并清除 Avalonia 默认 disabled overlay，避免变灰蒙蒙的难看效果
        -->
        <Style Selector="Button.date-nav">
            <Setter Property="Foreground" Value="#07C160" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.date-nav:disabled">
            <Setter Property="Foreground" Value="#BDBDBD" />
        </Style>
        <Style Selector="Button.date-nav:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <!--
            箭头字符 ‹ › (U+2039/U+203A) 字形重心偏下，
            通过底部 padding 将内容上移，使其视觉居中于圆形按钮
        -->
        <Style Selector="Button.date-nav /template/ ContentPresenter">
            <Setter Property="Padding" Value="0,0,0,3" />
        </Style>
        <!--  日统计项：emoji + 文案横排，用于 DayStats 区块的 6 个统计条目  -->
        <Style Selector="StackPanel.stat-item">
            <Setter Property="Margin" Value="0,0,12,4" />
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="6" />
        </Style>
        <Style Selector="TextBlock.stat-icon">
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style Selector="TextBlock.stat-text">
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  原版 date-bar: 白底，底部 1px 边框  -->
                <Border Margin="0,0,0,8" Padding="12,12" Background="White" BorderBrush="#F0F0F0"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto,*">
                        <!--  原版 date-nav: 72rpx≈36px 圆形，48rpx≈24px 绿色箭头，font-weight:300，flex 居中  -->
                        <Button Grid.Column="0" Width="36" Height="36" Padding="0"
                                HorizontalAlignment="Right" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Background="Transparent" BorderThickness="0" Classes="date-nav"
                                Command="{Binding PrevDayCommand}"
                                Content="‹" CornerRadius="18" FontSize="24" FontWeight="Light" />
                        <!--  原版 date-display: padding 0 20rpx，提供箭头与日期的间距  -->
                        <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center" Orientation="Horizontal"
                                    Spacing="6">
                            <TextBlock VerticalAlignment="Center" FontSize="17" FontWeight="Bold" Foreground="#333333"
                                       Text="{Binding DisplayDate}" />
                            <TextBlock VerticalAlignment="Center" FontSize="12" Opacity="0.5" Text="📅" />
                        </StackPanel>
                        <Button Grid.Column="2" Width="36" Height="36" Padding="0"
                                HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Background="Transparent" BorderThickness="0" Classes="date-nav"
                                Command="{Binding NextDayCommand}"
                                Content="›" CornerRadius="18" FontSize="24" FontWeight="Light"
                                IsEnabled="{Binding IsNextDayEnabled}" />
                    </Grid>
                </Border>

                <!--  原版 today-btn: 浅绿底，绿色文字  -->
                <Button Margin="0,0,0,8" Padding="0,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="#E8F9EF" BorderThickness="0"
                        Command="{Binding GoTodayCommand}"
                        Content="{DynamicResource Feeding_GoToday}"
                        CornerRadius="0" FontSize="13" Foreground="#07C160"
                        IsVisible="{Binding !IsToday}" />

                <Border Classes="weui-card" IsVisible="{Binding DayStats, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Classes="stat-item" IsVisible="{Binding DayStats.FeedCount}">
                            <TextBlock Classes="stat-icon" Text="🍼" />
                            <TextBlock Classes="stat-text">
                                <Run Text="喂奶" /><Run Text="{Binding DayStats.FeedCount}" /><Run Text="次 · " /><Run Text="{Binding DayStats.TotalMilk}" /><Run Text="ml" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Classes="stat-item" IsVisible="{Binding DayStats.BreastCount}">
                            <TextBlock Classes="stat-icon" Text="🤱" />
                            <TextBlock Classes="stat-text">
                                <Run Text="亲喂" /><Run Text="{Binding DayStats.BreastCount}" /><Run Text="次" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Classes="stat-item" IsVisible="{Binding DayStats.DiaperCount}">
                            <TextBlock Classes="stat-icon" Text="💩" />
                            <TextBlock Classes="stat-text">
                                <Run Text="{Binding DayStats.DiaperCount}" /><Run Text="尿布 · 便" /><Run Text="{Binding DayStats.DirtyDiaperCount}" /><Run Text=" · 尿" /><Run Text="{Binding DayStats.WetDiaperCount}" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Classes="stat-item" IsVisible="{Binding DayStats.WaterCount}">
                            <TextBlock Classes="stat-icon" Text="💧" />
                            <TextBlock Classes="stat-text">
                                <Run Text="喝水" /><Run Text="{Binding DayStats.WaterCount}" /><Run Text="次 · " /><Run Text="{Binding DayStats.WaterTotalMl}" /><Run Text="ml" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Classes="stat-item" IsVisible="{Binding DayStats.SupplementCount}">
                            <TextBlock Classes="stat-icon" Text="💊" />
                            <TextBlock Classes="stat-text">
                                <Run Text="补给" /><Run Text="{Binding DayStats.SupplementCount}" /><Run Text="次" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Classes="stat-item" IsVisible="{Binding DayStats.SleepTotalMin}">
                            <TextBlock Classes="stat-icon" Text="😴" />
                            <TextBlock Classes="stat-text">
                                <Run Text="睡眠" /><Run Text="{Binding DayStats.SleepTotalMin}" /><Run Text="分钟" />
                            </TextBlock>
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Feeding_RecordList}" />
                </Border>

                <!--  类型筛选条：横向滚动 Pill 标签，选中态绿底白字  -->
                <ScrollViewer Margin="12,0,12,8" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Padding="14,6"
                                Background="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterBgConverter}}"
                                BorderThickness="0"
                                Command="{Binding ApplyTypeFilterCommand}"
                                CommandParameter="all"
                                Content="{DynamicResource Feeding_FilterAll}"
                                CornerRadius="16" FontSize="13"
                                Foreground="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterFgConverter}}" />
                        <Button Padding="14,6"
                                Background="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterBgConverter}, ConverterParameter=feed}"
                                BorderThickness="0"
                                Command="{Binding ApplyTypeFilterCommand}"
                                CommandParameter="feed"
                                Content="{DynamicResource Feeding_FilterFeed}"
                                CornerRadius="16" FontSize="13"
                                Foreground="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterFgConverter}, ConverterParameter=feed}" />
                        <Button Padding="14,6"
                                Background="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterBgConverter}, ConverterParameter=sleep}"
                                BorderThickness="0"
                                Command="{Binding ApplyTypeFilterCommand}"
                                CommandParameter="sleep"
                                Content="{DynamicResource Feeding_FilterSleep}"
                                CornerRadius="16" FontSize="13"
                                Foreground="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterFgConverter}, ConverterParameter=sleep}" />
                        <Button Padding="14,6"
                                Background="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterBgConverter}, ConverterParameter=diaper}"
                                BorderThickness="0"
                                Command="{Binding ApplyTypeFilterCommand}"
                                CommandParameter="diaper"
                                Content="{DynamicResource Feeding_FilterDiaper}"
                                CornerRadius="16" FontSize="13"
                                Foreground="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterFgConverter}, ConverterParameter=diaper}" />
                        <Button Padding="14,6"
                                Background="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterBgConverter}, ConverterParameter=activity}"
                                BorderThickness="0"
                                Command="{Binding ApplyTypeFilterCommand}"
                                CommandParameter="activity"
                                Content="{DynamicResource Feeding_FilterActivity}"
                                CornerRadius="16" FontSize="13"
                                Foreground="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterFgConverter}, ConverterParameter=activity}" />
                        <Button Padding="14,6"
                                Background="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterBgConverter}, ConverterParameter=other}"
                                BorderThickness="0"
                                Command="{Binding ApplyTypeFilterCommand}"
                                CommandParameter="other"
                                Content="{DynamicResource Feeding_FilterOther}"
                                CornerRadius="16" FontSize="13"
                                Foreground="{Binding SelectedFilter, Converter={x:Static v:FeedingView.FilterFgConverter}, ConverterParameter=other}" />
                    </StackPanel>
                </ScrollViewer>

                <ItemsControl ItemsSource="{Binding Records}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecordDisplayItem">
                            <!--
                                滑动行结构（对齐小程序 swipe-row）：
                                - 外层 Panel 裁剪溢出，固定圆角
                                - 底层：红色"删除"按钮，右侧定位，默认被卡片遮住
                                - 上层：卡片内容，通过 RenderTransform 平移露出删除按钮
                            -->
                            <Panel Margin="12,4" ClipToBounds="True">
                                <!--  底层删除按钮：对齐小程序 delete-action，红底白字  -->
                                <Border Width="72" HorizontalAlignment="Right" Background="#FA5151" CornerRadius="0,8,8,0"
                                        Tag="{Binding .}"
                                        Tapped="OnDeleteTap">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{DynamicResource Common_Delete}" />
                                </Border>
                                <!--  上层卡片：白底，8px 圆角，12px padding，弱阴影  -->
                                <!--  用 Tapped（轻触手势）替代 PointerPressed，避免上下滑动滚动页面时误触编辑  -->
                                <Border Padding="12" Background="White" BoxShadow="0 1 4 0 #08000000"
                                        Classes.swipe-open="{Binding IsSwipeOpen}"
                                        CornerRadius="8" PointerCaptureLost="OnCardPointerCaptureLost" PointerMoved="OnCardPointerMoved"
                                        PointerPressed="OnCardPointerPressed" PointerReleased="OnCardPointerReleased"
                                        RenderTransform="{Binding SwipeTransform}"
                                        Tag="{Binding .}"
                                        Tapped="OnRecordTap">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
                                        <!--  原版 card-left: 时间在左侧  -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#999999"
                                                   Text="{Binding TimeText}" />
                                        <!--  原版 card-icon: 60rpx≈30px 圆角方框，#f9f9f9 底  -->
                                        <Border Grid.Row="0" Grid.Column="1" Width="30" Height="30"
                                                Margin="0,0,8,0" Background="#F9F9F9" CornerRadius="8">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Text="{Binding Icon}" />
                                        </Border>
                                        <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" FontSize="14"
                                                   FontWeight="Medium" Foreground="#333333"
                                                   Text="{Binding TitleText}" />
                                        <TextBlock Grid.Row="0" Grid.Column="4" Margin="0,0,8,0" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#999999"
                                                   IsVisible="{Binding SubText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Text="{Binding SubText}" />
                                        <!--  extra（右侧绿色强调，对齐小程序 card-extra #07c160）  -->
                                        <TextBlock Grid.Row="0" Grid.Column="5" Margin="0,0,0,0" VerticalAlignment="Center"
                                                   FontSize="12" FontWeight="Medium" Foreground="#07C160"
                                                   IsVisible="{Binding ExtraText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Text="{Binding ExtraText}" />
                                        <!--  备注（对齐小程序 card-note：浅灰背景块 + 深灰文字），从标题列开始对齐  -->
                                        <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="4" Margin="0,6,0,0"
                                                Padding="8,6" HorizontalAlignment="Left" Background="#F7F7F7" CornerRadius="6"
                                                IsVisible="{Binding NoteText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock FontSize="12" Foreground="#666666" Text="{Binding NoteText}" TextWrapping="Wrap" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,40" HorizontalAlignment="Center" FontSize="13"
                           Foreground="{StaticResource WeuiFg2Brush}"
                           IsVisible="{Binding Records.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}"
                           Text="{DynamicResource Feeding_NoRecords}" />

            </StackPanel>
        </ScrollViewer>

        <Border Margin="0,0,0,80" Padding="20,10" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Background="#CC000000" CornerRadius="8"
                IsVisible="{Binding ShowToast}">
            <TextBlock FontSize="13" Foreground="White" Text="{Binding ToastMessage}" />
        </Border>

        <controls:DialogHost Title="{DynamicResource Feeding_DeleteConfirmTitle}"
                             CancelCommand="{Binding CancelDeleteCommand}"
                             CancelText="{DynamicResource Common_Cancel}"
                             ConfirmCommand="{Binding ConfirmDeleteCommand}"
                             ConfirmText="{DynamicResource Feeding_DeleteConfirmTitle}"
                             IsOpen="{Binding ShowDeleteConfirm}">
            <controls:DialogHost.MessageContent>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontSize="13" Foreground="#666" Text="{DynamicResource Feeding_DeleteConfirmMsg}" TextAlignment="Center" />
                    <TextBlock FontSize="13" Foreground="#999" Text="{Binding DeleteItemTitle}" TextAlignment="Center" />
                </StackPanel>
            </controls:DialogHost.MessageContent>
        </controls:DialogHost>

        <!--
            编辑记录抽屉已移除：复用 MainShellViewModel.RecordSheet 的编辑模式，
            由 FeedingViewModel.EditRequested 事件触发 MainShellViewModel.OpenEditRecord，
            统一使用 RecordSheetView 底部抽屉，所有字段与新建一致。
        -->

    </Panel>
</UserControl>
