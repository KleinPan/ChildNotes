<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:v="using:ChildNotes.Views"
             xmlns:m="using:ChildNotes.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.SyncSettingsView"
             x:DataType="vm:SyncSettingsViewModel"
             Background="{StaticResource WeuiBg0Brush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 顶栏 -->
        <Border Grid.Row="0" Classes="nav-bar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Classes="nav-back" Command="{Binding BackCommand}"/>
                <TextBlock Grid.Column="1" Classes="nav-title" Text="{DynamicResource Sync_Title}"/>
                <TextBlock Grid.Column="2" Text=" " Width="40"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 同步（核心操作区：开关 + 同步状态合并） -->
                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Sync_SyncLabel}"/>
                </Border>
                <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}" Margin="12,4">
                    <StackPanel>
                        <Grid Margin="14,12" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Sync_EnableCloud}" FontSize="15"/>
                                <TextBlock Text="{DynamicResource Sync_EnableCloudHint}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding Enabled}"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource WeuiFg3Brush}" Margin="14,0"/>
                        <Grid Margin="14,12" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding LastSyncText}" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 立即同步（主操作按钮） -->
                <Button Content="{Binding SyncButtonText}"
                        Classes="weui-btn primary" Margin="12,8,12,16" HorizontalAlignment="Stretch"
                        Command="{Binding SyncNowCommand}" IsEnabled="{Binding !IsSyncing}"/>

                <!-- 服务器（地址可配置，后期可隐藏编辑入口改为只读） -->
                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Sync_Server}"/>
                </Border>
                <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}" Margin="12,4">
                    <StackPanel>
                        <!-- 开发版：可编辑 TextBox + 保存按钮 -->
                        <Grid Margin="14,12" ColumnDefinitions="80,*,Auto"
                              IsVisible="{Binding IsServerUrlEditable}">
                            <TextBlock Grid.Column="0" Text="{DynamicResource Sync_AddressLabel}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding ServerUrlInput}" FontSize="13"
                                     PlaceholderText="https://api.example.com"
                                     VerticalAlignment="Center"
                                     BorderThickness="0" Padding="0"/>
                            <Button Grid.Column="2" Content="{DynamicResource Common_Save}" Classes="weui-btn mini primary"
                                    Command="{Binding SaveServerUrlCommand}"
                                    IsVisible="{Binding IsServerUrlDirty}"
                                    Margin="8,0,0,0"/>
                        </Grid>
                        <!-- 当前生效地址（含回退到默认值的提示）。开发版仅编辑后显示，正式版始终显示 -->
                        <Border Height="1" Background="{StaticResource WeuiFg3Brush}" Margin="14,0"
                                IsVisible="{Binding IsServerUrlDirty}"/>
                        <Grid Margin="14,8" ColumnDefinitions="80,*"
                              IsVisible="{Binding IsServerUrlDirty}">
                            <TextBlock Grid.Column="0" Text="{DynamicResource Sync_CurrentEffect}" FontSize="12" Foreground="{StaticResource WeuiFg2Brush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ServerUrlDisplay}" FontSize="12"
                                       Foreground="{StaticResource WeuiFg2Brush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <!-- 正式版：只读展示当前生效地址 -->
                        <Grid Margin="14,12" ColumnDefinitions="80,*"
                              IsVisible="{Binding !IsServerUrlEditable}">
                            <TextBlock Grid.Column="0" Text="{DynamicResource Sync_AddressLabel}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ServerUrlDisplay}" FontSize="13"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 网络状态 -->
                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Sync_NetworkStatus}"/>
                </Border>
                <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}" Margin="12,4">
                    <Grid Margin="14,12" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding NetworkStateText}" FontSize="14"/>
                        <Ellipse Grid.Column="1" Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="{Binding IsOnline, Converter={x:Static v:SyncSettingsView.OnlineColorConverter}}"/>
                    </Grid>
                </Border>

                <!-- 同步日志（最近 10 条，按时间倒序） -->
                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Sync_SyncLog}"/>
                </Border>
                <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}" Margin="12,4">
                    <!-- 限定最大高度，超出后内部独立垂直滚动；不影响整页滚动 -->
                    <ScrollViewer MaxHeight="280" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding SyncLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="m:SyncLogEntry">
                                        <StackPanel Margin="14,10" Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding DoneAt, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                           FontSize="13" FontWeight="Medium"/>
                                                <!-- 状态标识：颜色区分 success/failed/running -->
                                                <Border Grid.Column="1" Padding="6,2" CornerRadius="4"
                                                        Background="{Binding Status, Converter={x:Static v:SyncSettingsView.SyncLogStatusBrushConverter}}">
                                                    <TextBlock Text="{Binding Status, Converter={x:Static v:SyncSettingsView.SyncLogStatusTextConverter}}"
                                                               FontSize="11" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding DataVolume}" FontSize="12"
                                                       Foreground="{StaticResource WeuiFg1Brush}"
                                                       IsVisible="{Binding DataVolume, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="{Binding Message}" FontSize="12"
                                                       Foreground="{StaticResource WeuiFg1Brush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- 空状态：暂无日志 -->
                            <TextBlock Text="{DynamicResource Sync_NoLog}" FontSize="13"
                                       Foreground="{StaticResource WeuiFg2Brush}"
                                       HorizontalAlignment="Center" Margin="0,20"
                                       IsVisible="{Binding SyncLogs.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- 说明 -->
                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Sync_NotesTitle}"/>
                </Border>
                <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}" Margin="12,4,12,24">
                    <StackPanel Margin="14,12" Spacing="6">
                        <TextBlock Text="{DynamicResource Sync_Note1}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource Sync_Note2}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource Sync_Note3}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource Sync_Note4}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource Sync_Note5}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,80"
                Background="#CC000000" CornerRadius="8" Padding="20,10" IsVisible="{Binding ShowToast}">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
