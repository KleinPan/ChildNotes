<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChildNotes.Views.LoadingView"
             Background="{StaticResource WeuiBg0Brush}">

    <Grid>
        <!-- 育儿小知识卡片（居中，立即可见不依赖动画） -->
        <Border x:Name="TipBorder"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Margin="24,0,24,120"
                Background="{StaticResource WeuiBg2Brush}"
                CornerRadius="{StaticResource WeuiCardRadius}"
                Padding="20,16"
                MaxWidth="340">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                    <TextBlock Text="💡" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="育儿小知识" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource WeuiGreenBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TipText" Text="" FontSize="14"
                           Foreground="{StaticResource WeuiFg0Brush}"
                           TextWrapping="Wrap" LineHeight="22"
                           TextAlignment="Center" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 底部 indeterminate 进度条（Avalonia 内置循环动画） -->
        <ProgressBar x:Name="ProgressBar"
                     HorizontalAlignment="Center" VerticalAlignment="Bottom"
                     Margin="0,0,0,80"
                     Width="120" Height="3"
                     IsIndeterminate="True"
                     Foreground="{StaticResource WeuiGreenBrush}"
                     Background="{StaticResource WeuiBg1Brush}"
                     CornerRadius="1.5"/>
    </Grid>
</UserControl>
