<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChildNotes.Views.LoadingView"
             Background="{StaticResource WeuiBg0Brush}">

    <Grid>
        <!-- 顶部 logo 区（与 LoginView 顶部样式一致，视觉延续） -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,80">
            <Border x:Name="LogoBorder" Width="84" Height="84" CornerRadius="42"
                    Background="{StaticResource WeuiGreenBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,16"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0.6" ScaleY="0.6"/>
                </Border.RenderTransform>
                <TextBlock Text="👶" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="TitleText" Text="成长记录" FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center" Opacity="0"/>
            <TextBlock x:Name="SubtitleText" Text="记录宝宝成长的每一天" FontSize="13"
                       Foreground="{StaticResource WeuiFg1Brush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0"/>
        </StackPanel>

        <!-- 育儿小知识区（Logo 下方，进度条上方） -->
        <Border x:Name="TipBorder"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Margin="24,200,24,0"
                Background="{StaticResource WeuiBg2Brush}"
                CornerRadius="{StaticResource WeuiCardRadius}"
                Padding="16,12"
                MaxWidth="320"
                Opacity="0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="💡" FontSize="14" Margin="0,0,6,0"/>
                    <TextBlock Text="育儿小知识" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource WeuiGreenBrush}"/>
                </StackPanel>
                <TextBlock x:Name="TipText" Text="" FontSize="13"
                           Foreground="{StaticResource WeuiFg0Brush}"
                           TextWrapping="Wrap" LineHeight="20"/>
            </StackPanel>
        </Border>

        <!-- 底部 indeterminate 进度条（Avalonia 内置循环动画） -->
        <ProgressBar x:Name="ProgressBar"
                     HorizontalAlignment="Center" VerticalAlignment="Bottom"
                     Margin="0,0,0,80"
                     Width="120" Height="3"
                     IsIndeterminate="True"
                     Foreground="{StaticResource WeuiGreenBrush}"
                     Background="{StaticResource WeuiBg1Brush}"
                     Opacity="0"
                     CornerRadius="1.5"/>
    </Grid>
</UserControl>
