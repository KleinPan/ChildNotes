<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:v="using:ChildNotes.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.HomeView"
             x:DataType="vm:HomeViewModel"
             Background="{StaticResource WeuiBg0Brush}">

    <UserControl.Styles>
        <Style Selector="Border.baby-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,16,14,10"/>
            <Setter Property="Margin" Value="12,12,12,0"/>
            <!-- 原版阴影: 0 2rpx 16rpx rgba(0,0,0,0.04) -->
            <Setter Property="BoxShadow" Value="0 1 8 0 #0A000000"/>
        </Style>
        <Style Selector="Border.stats-area">
            <!-- 原版 bs-stats: #f9fafb 底色，14rpx 圆角 -->
            <Setter Property="Background" Value="{StaticResource StatsAreaBgBrush}"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Margin" Value="10,12,10,12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Border.mini-card-row">
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>
        <Style Selector="Border.ai-status-card">
            <Setter Property="Background" Value="{StaticResource AiStatusBgBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="12,8"/>
            <Setter Property="BoxShadow" Value="0 1 8 0 #0A000000"/>
        </Style>
        <Style Selector="Border.quick-panel">
            <Setter Property="Background" Value="White"/>
            <!-- 原版 record-drawer 圆角 32rpx ≈ 16px -->
            <Setter Property="CornerRadius" Value="16,16,0,0"/>
            <!-- 原版顶部阴影: 0 -4rpx 30rpx rgba(0,0,0,0.08) -->
            <Setter Property="BoxShadow" Value="0 -2 15 0 #14000000"/>
        </Style>
        <Style Selector="Border.quick-handle">
            <!-- 原版 pull-tab 凸型拉手 -->
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="Margin" Value="0,-8,0,8"/>
            <Setter Property="BoxShadow" Value="0 3 10 0 #1F000000, 0 1 3 0 #10000000"/>
        </Style>
        <Style Selector="Border.quick-item">
            <!-- 原版 action-item: bg-1 底，16rpx 圆角 -->
            <Setter Property="Background" Value="{StaticResource WeuiBg1Brush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
        <Style Selector="Border.section-header">
            <Setter Property="Margin" Value="12,12,12,4"/>
        </Style>
        <!-- 追踪卡片头部胶囊按钮：对齐小程序端 v-btn-outline / at-btn-outline 基线 -->
        <Style Selector="Button.tracker-btn-outline">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <!-- 追踪卡片头部胶囊按钮：对齐小程序端 v-btn / at-btn 基线（蓝色强调） -->
        <Style Selector="Button.tracker-btn-primary">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="{StaticResource WeuiBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Panel>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">

            <Border Classes="baby-card">
                <StackPanel Spacing="12">
                    <!-- 原版 bs-top: 头像 + 名称/月龄 + 统计/签到按钮 -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26" Background="{StaticResource AvatarGradientBrush}" Margin="0,0,12,0">
                            <TextBlock Text="{Binding BabyAvatar}" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="{Binding BabyName}" FontSize="19" FontWeight="Bold" Foreground="#1A1A1A"/>
                            <Border Background="#07C16014" CornerRadius="12" Padding="9,3" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding BabyAgeText}" FontSize="12" Foreground="#07C160" FontWeight="Medium"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <!-- 原版 bs-action-entry.stats: 浅蓝底 + 蓝边框 -->
                            <Button Command="{Binding GoStatisticsCommand}" Width="44" Height="52" CornerRadius="8" Background="#F5FBFF" BorderBrush="#E8F5FF" BorderThickness="1" Padding="0">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="📊" FontSize="17" HorizontalAlignment="Center"/>
                                    <TextBlock Text="统计" FontSize="11" Foreground="#0A84FF" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- 原版 bs-action-entry.sign: 浅橙底 + 橙边框 -->
                            <Button Command="{Binding GoCheckInCommand}" Width="44" Height="52" CornerRadius="8" Background="#FFF7F1" BorderBrush="#FFE7D6" BorderThickness="1" Padding="0">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="✓" FontSize="17" Foreground="#E86F24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="签到" FontSize="11" Foreground="#E86F24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 原版 bs-stats: 2x2 统计卡片网格，带分隔线 -->
            <Border Classes="stats-area">
                <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="*,*">
                    <!-- 左列：喂奶 + 尿布 -->
                    <Border Grid.Row="0" Grid.Column="0" Classes="mini-card-row">
                        <Border Background="White" CornerRadius="6" Padding="8,6" BoxShadow="0 0 0 1 #08000000">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" Width="3" Background="{StaticResource FeedAccentBrush}" CornerRadius="1.5" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="🍼 距上次喂奶" FontSize="10" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding LastFeedAgoText}" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                                        <TextBlock Text="{Binding LastFeedSummary}" FontSize="10" Foreground="#999999" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" Classes="mini-card-row">
                        <Border Background="White" CornerRadius="6" Padding="8,6" BoxShadow="0 0 0 1 #08000000">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" Width="3" Background="{StaticResource DiaperAccentBrush}" CornerRadius="1.5" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="💩 换尿布" FontSize="10" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding DiaperTodayText}" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                                        <TextBlock Text="{Binding DiaperDetailText}" FontSize="10" Foreground="#999999" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>
                    <!-- 中间分隔线 -->
                    <Border Grid.RowSpan="2" Grid.Column="1" Width="1" Background="{StaticResource StatsSplitBrush}"/>
                    <!-- 右列：睡眠 + 成长 -->
                    <Border Grid.Row="0" Grid.Column="2" Classes="mini-card-row">
                        <Border Background="White" CornerRadius="6" Padding="8,6" BoxShadow="0 0 0 1 #08000000">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" Width="3" Background="{StaticResource SleepAccentBrush}" CornerRadius="1.5" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="😴 今日已睡" FontSize="10" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding SleepTodayText}" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                                        <TextBlock Text="1次" FontSize="10" Foreground="#999999" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" Classes="mini-card-row">
                        <Border Background="White" CornerRadius="6" Padding="8,6" BoxShadow="0 0 0 1 #08000000">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" Width="3" Background="{StaticResource GrowthAccentBrush}" CornerRadius="1.5" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="📏 身高体重" FontSize="10" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding LatestHeightText}" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                                        <TextBlock Text="/" FontSize="10" Foreground="#999999" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding LatestWeightText}" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <Border Classes="ai-status-card">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource icon-sun}" Foreground="#FFC300" Width="24" Height="24"/>
                        <TextBlock Text="{Binding AiStatusTitle}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding AiStatusSubtitle}" FontSize="13" Foreground="{StaticResource WeuiGreenBrush}" Margin="32,0,0,0"/>
                    <TextBlock Text="—— 宝宝的变化 ~" FontSize="12" Foreground="{StaticResource WeuiFg2Brush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <PathIcon Data="{StaticResource icon-lightbulb}" Foreground="{StaticResource WeuiYellowBrush}" Width="14" Height="14"/>
                        <TextBlock Text="{Binding AiTipText}" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="weui-card" Margin="12,8,12,0">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                        <PathIcon Grid.Column="0" Data="{StaticResource icon-vaccine}" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="疫苗追踪" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding VaccineProgressText}" FontSize="12" Foreground="{StaticResource WeuiFg2Brush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="{Binding IsVaccineExpanded, Converter={x:Static v:HomeView.ExpandTextConverter}}" Classes="tracker-btn-outline" Margin="8,0,0,0"
                                Command="{Binding ToggleVaccinePanelCommand}"/>
                        <Button Grid.Column="4" Content="补记" Classes="tracker-btn-primary" Margin="6,0,0,0"/>
                    </Grid>
                    <ItemsControl IsVisible="{Binding IsVaccineExpanded}" ItemsSource="{Binding VaccineItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource WeuiBg1Brush}" CornerRadius="6" Padding="10,8" Margin="0,4,0,0">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Background="{StaticResource WeuiBg2Brush}" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource WeuiFg1Brush}"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DueText}" FontSize="12" Foreground="{StaticResource WeuiFg2Brush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Classes="weui-card">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <PathIcon Grid.Column="0" Data="{StaticResource icon-activity}" Foreground="{StaticResource WeuiRedBrush}" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="活动追踪" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <Button Grid.Column="2" Content="详情" Classes="tracker-btn-outline" Margin="8,0,0,0"/>
                    <Button Grid.Column="3" Content="记录" Classes="tracker-btn-primary" Margin="6,0,0,0"/>
                </Grid>
            </Border>

            <Border Height="8"/>

        </StackPanel>
    </ScrollViewer>

    <Border Classes="quick-panel" VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
        <StackPanel>
            <!-- 原版 panel-pull 凸型拉手 -->
            <Border Classes="quick-handle" HorizontalAlignment="Center">
                <Button Command="{Binding ToggleQuickRecordPanelCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="快捷记录" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource WeuiGreenBrush}" VerticalAlignment="Center"/>
                        <!-- 箭头：展开时▼（点击收起），收起时▲（点击展开更多） -->
                        <TextBlock Text="{Binding IsQuickRecordPanelOpen, Converter={x:Static v:HomeView.ArrowTextConverter}}" FontSize="12" Foreground="{StaticResource WeuiGreenBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding IsQuickRecordPanelOpen, Converter={x:Static v:HomeView.ExpandTextConverter}}" FontSize="12" Foreground="{StaticResource WeuiGreenBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>
            <!-- 原版 actions-grid: 默认显示第一行（3 项），展开显示全部 9 项 -->
            <ItemsControl ItemsSource="{Binding VisibleQuickActions}" Padding="12,0,12,12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="0,8"
                                HorizontalContentAlignment="Center" HorizontalAlignment="Stretch"
                                Command="{Binding $parent[ItemsControl].((vm:HomeViewModel)DataContext).QuickRecordCommand}"
                                CommandParameter="{Binding Type}"
                                Click="OnQuickActionClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="5">
                                <!-- 原版 action-icon: 72rpx≈36px，18rpx≈9px 圆角 -->
                                <Border Width="36" Height="36" CornerRadius="9" Background="{Binding IconBg}">
                                    <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="11" Foreground="#1A1A1A" FontWeight="Medium" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>

    </Panel>
</UserControl>