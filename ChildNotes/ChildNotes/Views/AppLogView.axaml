<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:v="using:ChildNotes.Views"
             xmlns:infra="using:ChildNotes.Infrastructure"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.AppLogView"
             x:DataType="vm:AppLogViewModel"
             Background="{StaticResource WeuiBg0Brush}">

    <UserControl.Styles>
        <!-- 搜索框：圆角胶囊形，浅灰底，对齐微信风格（原 weui-search 类未定义，此处补齐） -->
        <Style Selector="TextBox.log-search">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{StaticResource WeuiBg0Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WeuiFg3Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="PlaceholderForeground" Value="{StaticResource WeuiFg2Brush}"/>
        </Style>

        <!-- 级别筛选按钮：未选中=描边浅灰，选中=实心主色。对齐 WeUI mini 按钮规范 -->
        <Style Selector="Button.lvl-btn">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="{StaticResource WeuiBtnRadius}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource WeuiFg3Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="RenderTransform" Value="none"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08" Easing="QuadraticEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.lvl-btn:pressed">
            <Setter Property="RenderTransform" Value="scale(0.96)"/>
        </Style>
        <!-- 选中态：实心 WeUI 主色（绿），白字，无边框 -->
        <Style Selector="Button.lvl-btn.selected">
            <Setter Property="Background" Value="{StaticResource WeuiGreenBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WeuiGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- 日志列表：ListBox + VirtualizingStackPanel，固定行高，虚拟化生效 -->
        <!-- 关键：必须用 ListBox（内部 ScrollViewer 有约束高度），ItemsControl 在 ScrollViewer 内虚拟化失效 -->
        <Style Selector="ListBox.log-list">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>
        <!-- ListBoxItem：去掉默认 padding/margin/最小高，让固定行高精确生效 -->
        <!-- 此页只有一个 ListBox，直接用 ListBoxItem 选择器无需限定 class -->
        <Style Selector="ListBox.log-list > ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <!-- 去掉 ListBoxItem 默认选中/悬停背景（视觉由 log-row 控制） -->
        <Style Selector="ListBox.log-list > ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- 日志条目：单行固定高，白底卡片，行间距 4px -->
        <!-- 固定高度让 VirtualizingStackPanel 可精确计算可视区，2000 条也只渲染 ~20 条 -->
        <Style Selector="Border.log-row">
            <Setter Property="Background" Value="{StaticResource WeuiBg2Brush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <!-- 选中项（点击展开）：解除固定高度，消息换行显示完整内容 -->
        <Style Selector="ListBox.log-list > ListBoxItem:selected > Border.log-row">
            <Setter Property="Height" Value="NaN"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- 日志元信息行：徽章 + 时间 + Tag + 消息，列定义 Auto,Auto,Auto,* -->
        <!-- 消息列须为 *（占满剩余空间），TextWrapping=Wrap 才能正确计算换行宽度 -->
        <!-- 注意：ColumnDefinitions 不是 StyledProperty，须在 Grid 上直接声明 -->
        <Style Selector="Grid.log-meta">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- 日志时间戳：浅灰小字 -->
        <Style Selector="TextBlock.log-time">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg2Brush}"/>
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,monospace"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- 日志 Tag：中灰等宽 -->
        <Style Selector="TextBlock.log-tag">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,monospace"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
        <!-- 日志正文：深灰等宽，单行省略（选中展开时才换行） -->
        <Style Selector="TextBlock.log-msg">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}"/>
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,monospace"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
        <!-- 选中展开时：消息换行显示完整内容 -->
        <Style Selector="ListBox.log-list > ListBoxItem:selected TextBlock.log-msg">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="None"/>
            <Setter Property="Margin" Value="6,2,0,0"/>
        </Style>
        <!-- 级别徽章文字 -->
        <Style Selector="Border.log-badge TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 顶栏"清空"按钮：与 nav-back 一致的无边框风格 -->
        <Style Selector="Button.nav-text-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.nav-text-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource WeuiBgColorActiveBrush}"/>
        </Style>
        <Style Selector="Button.nav-text-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource WeuiSeparatorBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- 顶栏 -->
        <Border Grid.Row="0" Classes="nav-bar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Classes="nav-back" Command="{Binding BackCommand}"/>
                <TextBlock Grid.Column="1" Classes="nav-title" Text="程序日志"/>
                <Button Grid.Column="2" Content="清空" Classes="nav-text-btn"
                        Command="{Binding ClearLogsCommand}"
                        Margin="0,0,4,0"/>
            </Grid>
        </Border>

        <!-- 工具栏：搜索框 + 级别筛选 -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="12,10">
            <TextBox Text="{Binding SearchText}" PlaceholderText="搜索 Tag 或内容…"
                     Classes="log-search"
                     InnerLeftContent="🔍"
                     Margin="0"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Classes="lvl-btn" Content="全部"
                        Command="{Binding SelectAllLevelCommand}"
                        Classes.selected="{Binding IsAllLevel}"/>
                <Button Classes="lvl-btn" Content="Info"
                        Command="{Binding SelectInfoLevelCommand}"
                        Classes.selected="{Binding IsInfoLevel}"/>
                <Button Classes="lvl-btn" Content="Warn"
                        Command="{Binding SelectWarnLevelCommand}"
                        Classes.selected="{Binding IsWarnLevel}"/>
                <Button Classes="lvl-btn" Content="Error"
                        Command="{Binding SelectErrorLevelCommand}"
                        Classes.selected="{Binding IsErrorLevel}"/>
                <Button Classes="lvl-btn" Content="AI"
                        Command="{Binding SelectAiLevelCommand}"
                        Classes.selected="{Binding IsAiLevel}"/>
            </StackPanel>
        </StackPanel>

        <!--
            日志列表：ListBox + VirtualizingStackPanel，虚拟化 + 固定行高
            - 必须用 ListBox（内部 ScrollViewer 有约束高度，虚拟化才能生效）
            - ItemsControl 直接放在 Grid.Row=* 里虚拟化失效（外层给无限高度）
            - 固定行高 32px 让 VirtualizingStackPanel 精确计算可视区，2000 条只渲染 ~20 条
            - 点击条目选中 → 选中项解除固定高度 + 消息换行，实现"点击展开查看完整日志"
            - Padding 留出 12px 左右边距，与工具栏/底栏对齐
        -->
        <ListBox Grid.Row="2" Classes="log-list"
                 ItemsSource="{Binding Filtered}"
                 Padding="12,4,12,8"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel CacheLength="0.3"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="infra:DevLogger+LogEntry">
                    <Border Classes="log-row">
                        <!--
                            单行布局：徽章 | 时间 | Tag | 消息（占满剩余）
                            列定义：Auto,Auto,Auto,* — 消息列必须是 *（占满剩余空间），
                            否则 TextWrapping=Wrap 在 Auto 列里无法计算换行宽度，展开无效。
                            选中展开时，log-row 解除固定高度，消息列换行撑高此 Grid。
                        -->
                        <Grid Classes="log-meta" ColumnDefinitions="Auto,Auto,Auto,*">
                            <!-- 级别徽章：Converter 绑定 Background，修复原四 class 冲突 Bug -->
                            <Border Grid.Column="0" Classes="log-badge"
                                    Width="44" Height="18" CornerRadius="4"
                                    Background="{Binding Level, Converter={x:Static v:AppConverters.LogLevelToBrush}}">
                                <TextBlock Text="{Binding Level}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Classes="log-time"
                                       Text="{Binding Time, StringFormat=HH:mm:ss}"/>
                            <TextBlock Grid.Column="2" Classes="log-tag"
                                       Text="{Binding Tag}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="3" Classes="log-msg"
                                       Text="{Binding Message}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部操作栏 -->
        <Border Grid.Row="3" Padding="14,10" Background="{StaticResource WeuiBg2Brush}"
                BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource WeuiFg1Brush}"
                           Text="{Binding Filtered.Count, StringFormat='筛选后 {0} 条'}"/>
                <Button Grid.Column="1" Content="导出 .txt"
                        Classes="weui-btn mini primary"
                        Command="{Binding ExportCommand}"
                        IsEnabled="{Binding !IsExporting}"/>
            </Grid>
        </Border>

        <!-- Toast -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="16,0,16,16"
                Background="#CC000000" CornerRadius="8" Padding="20,10"
                IsVisible="{Binding ShowToast}">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White"
                       FontSize="13" TextWrapping="Wrap" MaxWidth="320"/>
        </Border>
    </Grid>
</UserControl>
