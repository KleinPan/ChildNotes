<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:m="using:ChildNotes.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.AiAnalysisView"
             x:DataType="vm:AiAnalysisViewModel"
             Background="{StaticResource WeuiBg0Brush}">

    <UserControl.Styles>
        <Style Selector="Border.record-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BoxShadow" Value="0 1 8 0 #0A000000"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 统一顶栏 -->
        <Border Grid.Row="0" Classes="nav-bar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Classes="nav-back" Command="{Binding BackCommand}"/>
                <TextBlock Grid.Column="1" Classes="nav-title" Text="AI 分析"/>
                <Button Grid.Column="2" Classes="nav-back" Command="{Binding OpenConfigCommand}"
                        Content="⚙" FontSize="18" Padding="8,4" Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource WeuiFg1Brush}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Background="{StaticResource WeuiGreenBrush}" Padding="24,24" CornerRadius="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="宝宝喂养分析" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BabyName, StringFormat=当前宝宝：\{0\}}" FontSize="12" Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Panel IsVisible="{Binding !ShowDetail}" Margin="0,-12,0,0">
                    <StackPanel>

                        <Border Background="White" CornerRadius="8" Margin="12,4" Padding="14">
                            <StackPanel>
                                <TextBlock Text="分析说明" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="基于所选连续 7 天记录生成喂养、睡眠、健康和成长建议。" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="8" Margin="12,8" Padding="14">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,8">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="开始日期" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,4"/>
                                        <CalendarDatePicker SelectedDate="{Binding StartDate}" HorizontalAlignment="Stretch" FontSize="13"
                                                            PlaceholderText="选择开始日期"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="至" VerticalAlignment="Bottom" Margin="8,0" Foreground="{StaticResource WeuiFg1Brush}"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="结束日期" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,4"/>
                                        <CalendarDatePicker SelectedDate="{Binding EndDate}" HorizontalAlignment="Stretch" FontSize="13"
                                                            PlaceholderText="选择结束日期"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding RangeTip}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button Content="{Binding GenerateButtonText}" Classes="weui-btn primary" CornerRadius="6" Padding="0,14"
                                Command="{Binding GenerateCommand}" IsEnabled="{Binding CanGenerate}"
                                Margin="12,4" HorizontalAlignment="Stretch"/>
                        <Button Content="取消分析" Classes="weui-btn default" CornerRadius="6" Padding="0,12"
                                Command="{Binding CancelGenerateCommand}"
                                Margin="12,0,12,4" HorizontalAlignment="Stretch"
                                IsVisible="{Binding Generating}"/>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource WeuiRedBrush}" FontSize="13"
                                   Margin="12,8" TextWrapping="Wrap"
                                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <Border Classes="section-title" Margin="16,16,16,4">
                            <TextBlock Text="分析记录"/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Records}" Margin="12,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:AiAnalysisRecord">
                                    <Border Classes="record-card" PointerPressed="OnRecordTap" Tag="{Binding Id}">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding CreatedAtLabel}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="›" FontSize="18" Foreground="{StaticResource WeuiFg2Brush}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding RangeLabel}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding DataQualityTip}" FontSize="11" Foreground="{StaticResource WeuiOrangeBrush}" Margin="0,2,0,0"
                                                       IsVisible="{Binding DataQualityTip, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="{Binding Preview}" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Panel IsVisible="{Binding Records.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}" Margin="0,40,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="暂无分析记录" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="选择连续 7 天范围，点击上方按钮生成分析" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" HorizontalAlignment="Center" TextAlignment="Center" Margin="20,0"/>
                            </StackPanel>
                        </Panel>

                    </StackPanel>
                </Panel>

                <Panel IsVisible="{Binding ShowDetail}" Margin="0,-12,0,0">
                    <StackPanel>
                        <Border Background="White" CornerRadius="8" Margin="12,4" Padding="14">
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding DetailRangeLabel}" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}"/>
                                <TextBlock Text="{Binding DetailCreatedLabel, StringFormat=生成时间：\{0\}}" FontSize="12" Foreground="{StaticResource WeuiFg2Brush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding DetailQualityTip}" FontSize="12" Foreground="{StaticResource WeuiOrangeBrush}" Margin="0,4,0,0"
                                           IsVisible="{Binding DetailQualityTip, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="8" Margin="12,4" Padding="14">
                            <TextBlock Text="{Binding DetailText}" FontSize="14" TextWrapping="Wrap" LineHeight="22"/>
                        </Border>

                        <Button Content="返回列表" Classes="weui-btn default" CornerRadius="6" Padding="0,12"
                                Command="{Binding BackToListCommand}" Margin="12,8" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Panel>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,80"
                Background="#CC000000" CornerRadius="8" Padding="20,10" IsVisible="{Binding ShowToast}">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="13"/>
        </Border>

    </Grid>
</UserControl>
