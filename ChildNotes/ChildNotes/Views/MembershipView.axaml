<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:views="using:ChildNotes.Views"
             xmlns:dto="using:ChildNotes.Shared.Dtos"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.MembershipView"
             x:DataType="vm:MembershipViewModel"
             Background="{StaticResource WeuiBg0Brush}">

    <UserControl.Styles>
        <Style Selector="Border.plan-card">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,20"/>
            <Setter Property="Background" Value="{StaticResource WeuiBg2Brush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 统一顶栏 -->
        <Border Grid.Row="0" Classes="nav-bar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Classes="nav-back" Command="{Binding BackCommand}"/>
                <TextBlock Grid.Column="1" Classes="nav-title" Text="{DynamicResource Membership_Title}"/>
                <TextBlock Grid.Column="2" Text=" " Width="40"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 会员状态卡片 -->
                <Border Background="{StaticResource WeuiGreenBrush}" Padding="24,24" CornerRadius="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="13" Foreground="#CCFFFFFF" HorizontalAlignment="Center"
                                   Text="{Binding IsActive, Converter={x:Static views:MembershipView.IsMemberTextConverter}}"/>

                        <!-- AI 记次数（今日） -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <TextBlock FontSize="13" Foreground="#CCFFFFFF" VerticalAlignment="Center" Text="{DynamicResource Membership_AiToday}"/>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Margin="8,0,0,0">
                                <Run Text="{Binding AiNoteRemainingToday}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding AiNoteDailyLimit}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- AI 分析次数（本周） -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock FontSize="13" Foreground="#CCFFFFFF" VerticalAlignment="Center" Text="{DynamicResource Membership_AiWeek}"/>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Margin="8,0,0,0">
                                <Run Text="{Binding AiAnalysisRemainingThisWeek}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding AiAnalysisWeeklyLimit}"/>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock FontSize="12" Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,10,0,0"
                                   Text="{Binding ExpireAtText, StringFormat=会员到期：\{0\}}"
                                   IsVisible="{Binding IsActive}"/>
                    </StackPanel>
                </Border>

                <!-- 权益说明 -->
                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Membership_Benefits}"/>
                </Border>

                <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}" Margin="12,4">
                    <StackPanel>
                        <Grid Margin="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,12,0" FontSize="20" Text="✏️"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock FontSize="15" Text="{DynamicResource Membership_Benefit1Title}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,2,0,0"
                                           Text="{DynamicResource Membership_Benefit1Desc}"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"/>
                        <Grid Margin="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,12,0" FontSize="20" Text="📊"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock FontSize="15" Text="{DynamicResource Membership_Benefit2Title}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,2,0,0"
                                           Text="{DynamicResource Membership_Benefit2Desc}"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"/>
                        <Grid Margin="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,12,0" FontSize="20" Text="🎰"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock FontSize="15" Text="{DynamicResource Membership_Benefit3Title}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,2,0,0"
                                           Text="{DynamicResource Membership_Benefit3Desc}"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"/>
                        <Grid Margin="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,12,0" FontSize="20" Text="🖼️"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock FontSize="15" Text="{DynamicResource Membership_Benefit4Title}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,2,0,0"
                                           Text="{DynamicResource Membership_Benefit4Desc}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 套餐选择 -->
                <Border Classes="section-title">
                    <TextBlock Text="{DynamicResource Membership_SelectPlan}"/>
                </Border>

                <ItemsControl ItemsSource="{Binding Plans}" Margin="12,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dto:MembershipPlanDto">
                            <Border Classes="plan-card" Margin="0,0,0,8"
                                    PointerPressed="OnPlanCardTap"
                                    Tag="{Binding PlanType}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"/>
                                            <Border Background="{StaticResource WeuiGreenBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                    IsVisible="{Binding IsRecommended}">
                                                <TextBlock Text="{DynamicResource Membership_Recommended}" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="¥" FontSize="14" Foreground="{StaticResource WeuiGreenBrush}" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding PriceCents, Converter={x:Static views:MembershipView.CentsToYuanConverter}}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource WeuiGreenBrush}"/>
                                            <TextBlock Text="{Binding OriginalPriceCents, Converter={x:Static views:MembershipView.CentsToYuanConverter}, StringFormat=¥\{0\}}"
                                                       FontSize="13" Foreground="{StaticResource WeuiFg2Brush}"
                                                       TextDecorations="Strikethrough" Margin="8,0,0,0"
                                                       VerticalAlignment="Bottom"
                                                       IsVisible="{Binding OriginalPriceCents, Converter={x:Static views:MembershipView.IsPositiveConverter}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- 选中标记：✓ 图标，仅在选中时显示 -->
                                    <Border Grid.Column="1" Width="28" Height="28" CornerRadius="14"
                                            Background="{StaticResource WeuiGreenBrush}"
                                            VerticalAlignment="Center">
                                        <Border.IsVisible>
                                            <MultiBinding Converter="{x:Static views:MembershipView.PlanSelectedConverter}">
                                                <Binding Path="PlanType"/>
                                                <Binding Path="$parent[ItemsControl].DataContext.SelectedPlanType"/>
                                            </MultiBinding>
                                        </Border.IsVisible>
                                        <TextBlock Text="✓" Foreground="White" FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部支付按钮：显示"立即开通"+选中套餐名 -->
        <Border Grid.Row="2" Background="{StaticResource WeuiBg2Brush}" Padding="16,12">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource Membership_Selected}" FontSize="12" Foreground="{StaticResource WeuiFg2Brush}" VerticalAlignment="Center"/>
                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource WeuiGreenBrush}" VerticalAlignment="Center"
                               Text="{Binding SelectedPlanType, Converter={x:Static views:MembershipView.PlanTypeToNameConverter}}"/>
                </StackPanel>
                <Button Content="{DynamicResource Membership_Subscribe}" Classes="weui-btn primary" HorizontalAlignment="Stretch"
                        Command="{Binding PayCommand}" IsEnabled="{Binding !Paying}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,80"
                Background="#CC000000" CornerRadius="8" Padding="20,10" IsVisible="{Binding ShowToast}">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
