<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:v="using:ChildNotes.Views"
             xmlns:ctrl="using:ChildNotes.Controls"
             xmlns:s="using:ChildNotes.Services"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.RecordSheetView"
             x:DataType="vm:RecordSheetViewModel"
             IsVisible="{Binding IsVisible}">

    <UserControl.Styles>
        <Style Selector="Border.form-section">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style Selector="TextBlock.form-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="Border.type-tab">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Background" Value="{StaticResource WeuiBg1Brush}"/>
        </Style>
        <Style Selector="Border.type-tab.active">
            <Setter Property="Background" Value="{StaticResource WeuiGreenBrush}"/>
        </Style>
        <Style Selector="Border.type-tab TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.type-tab.active TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Border.type-card">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="Background" Value="{StaticResource WeuiBg1Brush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Border.type-card.active">
            <Setter Property="Background" Value="#E8F9EF"/>
            <Setter Property="BorderBrush" Value="{StaticResource WeuiGreenBrush}"/>
        </Style>
        <Style Selector="TextBox.form-input">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <!-- 疫苗时间轴样式 -->
        <Style Selector="Border.vf-entry">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="Border.vf-card">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.vf-card.done">
            <Setter Property="Background" Value="#EDFDF5"/>
            <Setter Property="BorderBrush" Value="#9EE6C1"/>
        </Style>
        <Style Selector="Border.vf-card.skipped">
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
        </Style>
        <Style Selector="Border.vf-card.replaced">
            <Setter Property="Background" Value="#EDFDF5"/>
            <Setter Property="BorderBrush" Value="#9EE6C1"/>
        </Style>
        <Style Selector="Border.vf-card.overdue">
            <Setter Property="Background" Value="#FFF4ED"/>
            <Setter Property="BorderBrush" Value="#FFBF9B"/>
        </Style>
        <Style Selector="Border.vf-card.due">
            <Setter Property="Background" Value="#FFFBE8"/>
            <Setter Property="BorderBrush" Value="#F4D35E"/>
        </Style>
        <Style Selector="Border.vf-card.soon">
            <Setter Property="Background" Value="#FFFBE8"/>
            <Setter Property="BorderBrush" Value="#F4D35E"/>
        </Style>
        <Style Selector="Border.vf-card.pending">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>
        <Style Selector="Panel.vf-axis">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style Selector="Border.vf-dot">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Background" Value="{StaticResource WeuiBlueBrush}"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Border.vf-segment">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="Background" Value="{StaticResource WeuiBg1Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Border.vf-segment.active">
            <Setter Property="Background" Value="{StaticResource WeuiBlueBrush}"/>
        </Style>
        <Style Selector="Border.vf-segment TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.vf-segment.active TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Button.vf-mark">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="{StaticResource WeuiBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.vf-skip">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FA9D3B"/>
            <Setter Property="BorderBrush" Value="#FA9D3B"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <!-- 异常表单 chip 样式：呼吸道多选 chip -->
        <Style Selector="Border.abn-chip">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.abn-chip.active">
            <Setter Property="Background" Value="#FFF3E0"/>
            <Setter Property="BorderBrush" Value="#FA9D3B"/>
        </Style>
        <Style Selector="Border.abn-chip TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        <Style Selector="Border.abn-chip.active TextBlock">
            <Setter Property="Foreground" Value="#E67E22"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <!-- 消化道异常 chip（红色强调，对齐小程序 .active-danger） -->
        <Style Selector="Border.abn-chip-danger">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.abn-chip-danger.active">
            <Setter Property="Background" Value="#FFEBEE"/>
            <Setter Property="BorderBrush" Value="#E74C3C"/>
        </Style>
        <Style Selector="Border.abn-chip-danger TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.abn-chip-danger.active TextBlock">
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <Border Classes="modal-mask" IsVisible="{Binding IsVisible}"/>

        <!-- 底部抽屉：MaxHeight 由 code-behind 根据软键盘状态动态调整，
             避免键盘弹出时遮挡输入框和保存按钮。
             x:Name=SheetRoot 供 code-behind 访问。 -->
        <Border x:Name="SheetRoot"
                Background="{StaticResource WeuiBg2Brush}" CornerRadius="16,16,0,0"
                VerticalAlignment="Bottom" MaxHeight="600" IsVisible="{Binding IsVisible}">

            <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding SheetTitle}" FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" FontSize="18" Padding="8,2"
                                Background="Transparent" BorderThickness="0"
                                Command="{Binding CloseCommand}"/>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ContentScroll" Grid.Row="1" Padding="16,16" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsFeed}}">
                            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,16">
                                <Border Grid.Column="0" Classes="type-tab"
                                        Classes.active="{Binding FeedForm.FeedType, Converter={x:Static v:AppConverters.IsBottle}}"
                                        PointerPressed="OnFeedBottle">
                                    <TextBlock Text="🍼 配方奶"/>
                                </Border>
                                <Border Grid.Column="1" Classes="type-tab" Margin="8,0"
                                        Classes.active="{Binding FeedForm.FeedType, Converter={x:Static v:AppConverters.IsBreast}}"
                                        PointerPressed="OnFeedBreast">
                                    <TextBlock Text="🤱 亲喂"/>
                                </Border>
                                <Border Grid.Column="2" Classes="type-tab"
                                        Classes.active="{Binding FeedForm.FeedType, Converter={x:Static v:AppConverters.IsExpressed}}"
                                        PointerPressed="OnFeedExpressed">
                                    <TextBlock Text="🍶 瓶喂母乳"/>
                                </Border>
                            </Grid>

                            <StackPanel IsVisible="{Binding FeedForm.FeedType, Converter={x:Static v:AppConverters.IsBreast}}">
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="← 左侧时长（分钟）"/>
                                        <TextBox Classes="form-input" Text="{Binding FeedForm.LeftDurationText}" PlaceholderText="0" KeyboardNavigation.IsTabStop="True"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="→ 右侧时长（分钟）"/>
                                        <TextBox Classes="form-input" Text="{Binding FeedForm.RightDurationText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding FeedForm.FeedType, Converter={x:Static v:AppConverters.NotBreast}}">
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="奶量（ml）"/>
                                        <TextBox Classes="form-input" Text="{Binding FeedForm.AmountText}" PlaceholderText="请输入奶量"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding FeedForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsDiaper}}">
                            <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,16">
                                <Border Grid.Column="0" Classes="type-card"
                                        Classes.active="{Binding DiaperForm.DiaperType, Converter={x:Static v:AppConverters.IsWet}}"
                                        PointerPressed="OnDiaperWet">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💧" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="嘘嘘" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="type-card" Margin="8,0"
                                        Classes.active="{Binding DiaperForm.DiaperType, Converter={x:Static v:AppConverters.IsDirty}}"
                                        PointerPressed="OnDiaperDirty">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💩" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="便便" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="type-card"
                                        Classes.active="{Binding DiaperForm.DiaperType, Converter={x:Static v:AppConverters.IsBoth}}"
                                        PointerPressed="OnDiaperBoth">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💧💩" FontSize="20" HorizontalAlignment="Center"/>
                                        <TextBlock Text="都有" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Classes="type-card" Margin="8,0,0,0"
                                        Classes.active="{Binding DiaperForm.DiaperType, Converter={x:Static v:AppConverters.IsDry}}"
                                        PointerPressed="OnDiaperDry">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="✅" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="干爽" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding DiaperForm.SelectedConsistency}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding DiaperForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsSleep}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="开始时间"/>
                                    <TimePicker SelectedTime="{Binding SleepForm.StartTimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="结束时间"/>
                                    <TimePicker SelectedTime="{Binding SleepForm.EndTimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsTemp}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="体温（℃）"/>
                                    <TextBox Classes="form-input" Text="{Binding TemperatureForm.TemperatureText}" PlaceholderText="输入体温"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section" Background="#FFF0F0" CornerRadius="8" Padding="10"
                                    IsVisible="{Binding TemperatureForm.IsFeverWarning}">
                                <TextBlock Text="⚠️ 体温 ≥ 37.3℃，保存后将触发发烧追踪" FontSize="12" Foreground="{StaticResource WeuiRedBrush}"/>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding TemperatureForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding TemperatureForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsGrowth}}">
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                <Border Grid.Column="0" Background="#F9F9F9" CornerRadius="12" Padding="0,16">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📏" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="身高" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBox Text="{Binding GrowthForm.HeightText}" PlaceholderText="0" Width="80" FontSize="22" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="8" Background="White"/>
                                            <TextBlock Text="cm" FontSize="14" Foreground="{StaticResource WeuiFg1Brush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="12" Padding="0,16" Margin="12,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⚖️" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="体重" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBox Text="{Binding GrowthForm.WeightText}" PlaceholderText="0" Width="80" FontSize="22" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="8" Background="White"/>
                                            <TextBlock Text="kg" FontSize="14" Foreground="{StaticResource WeuiFg1Brush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding GrowthForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsSupplement}}">
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                <Border Grid.Column="0" Classes="type-tab"
                                        Classes.active="{Binding SupplementForm.SuppType, Converter={x:Static v:AppConverters.IsMedicine}}"
                                        PointerPressed="OnSuppMedicine">
                                    <TextBlock Text="💊 用药"/>
                                </Border>
                                <Border Grid.Column="1" Classes="type-tab" Margin="12,0,0,0"
                                        Classes.active="{Binding SupplementForm.SuppType, Converter={x:Static v:AppConverters.IsNutrition}}"
                                        PointerPressed="OnSuppNutrition">
                                    <TextBlock Text="🥗 营养"/>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="名称"/>
                                    <TextBox Classes="form-input" Text="{Binding SupplementForm.Name}" PlaceholderText="如：维生素D、退烧药..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="剂量（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding SupplementForm.Dose}" PlaceholderText="如：1滴、5ml..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding SupplementForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding SupplementForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsPump}}">
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                <Border Grid.Column="0" Background="#F9F9F9" CornerRadius="12" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="左侧时长（分钟）" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,6"/>
                                        <TextBox Classes="form-input" Text="{Binding PumpForm.LeftDurationText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="12" Padding="12,10" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="右侧时长（分钟）" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,6"/>
                                        <TextBox Classes="form-input" Text="{Binding PumpForm.RightDurationText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                <Border Grid.Column="0" Background="#F9F9F9" CornerRadius="12" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="左侧奶量（ml）" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,6"/>
                                        <TextBox Classes="form-input" Text="{Binding PumpForm.LeftAmountText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="12" Padding="12,10" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="右侧奶量（ml）" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,6"/>
                                        <TextBox Classes="form-input" Text="{Binding PumpForm.RightAmountText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="总奶量（ml，选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding PumpForm.TotalAmountText}" PlaceholderText="不填则自动计算"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding PumpForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding PumpForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsComplementary}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="食物名称"/>
                                    <TextBox Classes="form-input" Text="{Binding ComplementaryForm.FoodName}" PlaceholderText="如：南瓜泥、米粉..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="质地"/>
                                    <Grid ColumnDefinitions="*,*,*">
                                        <Border Grid.Column="0" Classes="type-tab"
                                                Classes.active="{Binding ComplementaryForm.SelectedTexture, Converter={x:Static v:AppConverters.IsPuree}}"
                                                PointerPressed="OnTexturePuree">
                                            <TextBlock Text="泥糊"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="type-tab" Margin="8,0"
                                                Classes.active="{Binding ComplementaryForm.SelectedTexture, Converter={x:Static v:AppConverters.IsMashed}}"
                                                PointerPressed="OnTextureMashed">
                                            <TextBlock Text="碎末"/>
                                        </Border>
                                        <Border Grid.Column="2" Classes="type-tab"
                                                Classes.active="{Binding ComplementaryForm.SelectedTexture, Converter={x:Static v:AppConverters.IsLumpy}}"
                                                PointerPressed="OnTextureLumpy">
                                            <TextBlock Text="小块"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="食量（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding ComplementaryForm.AmountText}" PlaceholderText="如：2勺、半碗..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="反应"/>
                                    <Grid ColumnDefinitions="*,*,*,*">
                                        <Border Grid.Column="0" Classes="type-tab"
                                                Classes.active="{Binding ComplementaryForm.SelectedReaction, Converter={x:Static v:AppConverters.IsNoneReaction}}"
                                                PointerPressed="OnReactionNone">
                                            <TextBlock Text="无"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="type-tab" Margin="6,0"
                                                Classes.active="{Binding ComplementaryForm.SelectedReaction, Converter={x:Static v:AppConverters.IsAllergy}}"
                                                PointerPressed="OnReactionAllergy">
                                            <TextBlock Text="过敏"/>
                                        </Border>
                                        <Border Grid.Column="2" Classes="type-tab"
                                                Classes.active="{Binding ComplementaryForm.SelectedReaction, Converter={x:Static v:AppConverters.IsVomitReaction}}"
                                                PointerPressed="OnReactionVomit">
                                            <TextBlock Text="呕吐"/>
                                        </Border>
                                        <Border Grid.Column="3" Classes="type-tab" Margin="6,0,0,0"
                                                Classes.active="{Binding ComplementaryForm.SelectedReaction, Converter={x:Static v:AppConverters.IsDiarrheaReaction}}"
                                                PointerPressed="OnReactionDiarrhea">
                                            <TextBlock Text="腹泻"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding ComplementaryForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding ComplementaryForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsAbnormal}}">
                            <!-- 体温（选填）：对齐小程序 abnormal-form 的 temperature 字段语义 -->
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="体温（℃，选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding AbnormalForm.TemperatureText}" PlaceholderText="如有发热请填写"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section" Background="#FFF0F0" CornerRadius="8" Padding="10"
                                    IsVisible="{Binding AbnormalForm.IsFeverWarning}">
                                <TextBlock Text="⚠️ 体温 ≥ 37.3℃，建议持续监测并注意补水" FontSize="12" Foreground="{StaticResource WeuiRedBrush}"/>
                            </Border>

                            <!-- 呼吸道症状（多选 chip） -->
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="呼吸道症状（可多选）"/>
                                    <WrapPanel>
                                        <Border Classes="abn-chip"
                                                Classes.active="{Binding AbnormalForm.Respiratory, Converter={x:Static v:RecordSheetView.RespiratoryContainsCough}}"
                                                PointerPressed="OnRespCough">
                                            <TextBlock Text="咳嗽(轻微)"/>
                                        </Border>
                                        <Border Classes="abn-chip"
                                                Classes.active="{Binding AbnormalForm.Respiratory, Converter={x:Static v:RecordSheetView.RespiratoryContainsCoughFreq}}"
                                                PointerPressed="OnRespCoughFreq">
                                            <TextBlock Text="咳嗽(频繁)"/>
                                        </Border>
                                        <Border Classes="abn-chip"
                                                Classes.active="{Binding AbnormalForm.Respiratory, Converter={x:Static v:RecordSheetView.RespiratoryContainsSneeze}}"
                                                PointerPressed="OnRespSneeze">
                                            <TextBlock Text="打喷嚏"/>
                                        </Border>
                                        <Border Classes="abn-chip"
                                                Classes.active="{Binding AbnormalForm.Respiratory, Converter={x:Static v:RecordSheetView.RespiratoryContainsRhinorrhea}}"
                                                PointerPressed="OnRespRhinorrhea">
                                            <TextBlock Text="流鼻涕"/>
                                        </Border>
                                        <Border Classes="abn-chip"
                                                Classes.active="{Binding AbnormalForm.Respiratory, Converter={x:Static v:RecordSheetView.RespiratoryContainsCongestion}}"
                                                PointerPressed="OnRespCongestion">
                                            <TextBlock Text="鼻塞"/>
                                        </Border>
                                        <Border Classes="abn-chip"
                                                Classes.active="{Binding AbnormalForm.Respiratory, Converter={x:Static v:RecordSheetView.RespiratoryContainsTachypnea}}"
                                                PointerPressed="OnRespTachypnea">
                                            <TextBlock Text="呼吸急促"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- 消化道异常（呕吐单选） -->
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="消化道异常"/>
                                    <Grid ColumnDefinitions="*,*">
                                        <Border Grid.Column="0" Classes="abn-chip-danger"
                                                Classes.active="{Binding AbnormalForm.VomitType, Converter={x:Static v:AppConverters.IsVomitSpitUp}}"
                                                PointerPressed="OnVomitSpitUp">
                                            <TextBlock Text="溢奶(轻微)"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="abn-chip-danger" Margin="8,0,0,0"
                                                Classes.active="{Binding AbnormalForm.VomitType, Converter={x:Static v:AppConverters.IsVomitProjectile}}"
                                                PointerPressed="OnVomitProjectile">
                                            <TextBlock Text="喷射状呕吐(严重)"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 其他异常（自由文本） -->
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="其他异常"/>
                                    <TextBox Classes="form-input" Text="{Binding AbnormalForm.Other}"
                                             PlaceholderText="如：精神差、哭闹、皮疹、辅食后反应异常等"
                                             AcceptsReturn="True" TextWrapping="Wrap" MaxLength="300"/>
                                </StackPanel>
                            </Border>

                            <!-- 是否用药 -->
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="是否用药"/>
                                    <CheckBox Content="已服用药物" IsChecked="{Binding AbnormalForm.HasMedicine}"/>
                                </StackPanel>
                            </Border>

                            <!-- 备注（选填） -->
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding AbnormalForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>

                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding AbnormalForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsVaccine}}">
                            <!-- A. 添加自定义疫苗入口 -->
                            <Border Classes="vf-entry" PointerPressed="OnVaccineToggleCustomForm">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="添加自定义疫苗" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Text="添加后会进入当前宝宝的疫苗时间线" FontSize="11" Foreground="{StaticResource WeuiFg2Brush}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#EEF8FF" CornerRadius="12" Padding="10,3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding VaccineForm.ShowCustomVaccineForm, Converter={x:Static v:RecordSheetView.VaccineToggleTextConverter}}"
                                                   FontSize="12" Foreground="#0675B8"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- B. 自定义疫苗表单（折叠） -->
                            <StackPanel IsVisible="{Binding VaccineForm.ShowCustomVaccineForm}" Margin="0,0,0,12" Spacing="10">
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="疫苗名称"/>
                                        <TextBox Classes="form-input" Text="{Binding VaccineForm.CustomVaccineName}" PlaceholderText="如：流感疫苗加强针"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="类型"/>
                                        <Grid ColumnDefinitions="*,*">
                                            <Border Grid.Column="0" Classes="vf-segment" Margin="0,0,4,0"
                                                    Classes.active="{Binding VaccineForm.CustomVaccineCategory, Converter={x:Static v:AppConverters.IsCustomFree}}"
                                                    PointerPressed="OnCustomCategoryFree">
                                                <TextBlock Text="免费疫苗"/>
                                            </Border>
                                            <Border Grid.Column="1" Classes="vf-segment" Margin="4,0,0,0"
                                                    Classes.active="{Binding VaccineForm.CustomVaccineCategory, Converter={x:Static v:AppConverters.IsCustomPaid}}"
                                                    PointerPressed="OnCustomCategoryPaid">
                                                <TextBlock Text="自费疫苗"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="接种时间"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" Classes="form-input" Margin="0,0,8,0"
                                                     Text="{Binding VaccineForm.CustomVaccineAgeValue}" PlaceholderText="数值"/>
                                            <ComboBox Grid.Column="1" MinWidth="100"
                                                      SelectedIndex="{Binding VaccineForm.CustomVaccineAgeUnitIndex}"
                                                      ItemsSource="{Binding VaccineForm.CustomVaccineAgeUnits}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="预防疾病"/>
                                        <TextBox Classes="form-input" Text="{Binding VaccineForm.CustomVaccineDisease}" PlaceholderText="可不填"/>
                                    </StackPanel>
                                </Border>
                                <Button Content="加入时间线" Classes="weui-btn primary" HorizontalAlignment="Stretch"
                                        Click="OnAddCustomVaccine"/>
                            </StackPanel>

                            <!-- C. 已选剂次卡片 -->
                            <Border Classes="vf-entry" Background="#EEF8FF" BorderBrush="#BFE8FF"
                                    IsVisible="{Binding VaccineForm.SelectedPlan, Converter={x:Static v:RecordSheetView.IsNotNullConverter}}"
                                    Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="已选择" FontSize="11" Foreground="#0675B8"/>
                                        <TextBlock Text="{Binding VaccineForm.SelectedPlan.Name}" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource WeuiFg2Brush}">
                                            <Run Text="{Binding VaccineForm.SelectedPlan.AgeLabel}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding VaccineForm.SelectedPlan.RecommendedDateText}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding VaccineForm.SelectedPlan.StatusText}" FontSize="11" Foreground="#0675B8"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- D. 记录时间（用于已打/跳过） -->
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="接种日期"/>
                                    <DatePicker SelectedDate="{Binding VaccineForm.RecordDateText, Converter={x:Static v:DateTextToDateTimeOffsetConverter.Instance}}"
                                                FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="接种时间"/>
                                    <TimePicker SelectedTime="{Binding VaccineForm.RecordTimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>

                            <!-- E. 时间轴表头 -->
                            <Grid ColumnDefinitions="*,60,*" Margin="0,4,0,4">
                                <Border Grid.Column="0" Background="#EEF8FF" CornerRadius="6" Padding="8,6">
                                    <TextBlock Text="免费疫苗" FontSize="12" Foreground="#0675B8" HorizontalAlignment="Center" FontWeight="Medium"/>
                                </Border>
                                <Border Grid.Column="1" Background="#F3F4F6" CornerRadius="6" Padding="8,6" Margin="4,0">
                                    <TextBlock Text="时间" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="2" Background="#FFF7ED" CornerRadius="6" Padding="8,6">
                                    <TextBlock Text="自费疫苗" FontSize="12" Foreground="#B45309" HorizontalAlignment="Center" FontWeight="Medium"/>
                                </Border>
                            </Grid>

                            <!-- F. 时间轴分组 -->
                            <ItemsControl ItemsSource="{Binding VaccineForm.TimelineGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="s:VaccineTimelineGroup">
                                        <Grid ColumnDefinitions="*,60,*" Margin="0,4,0,0">
                                            <!-- 左：免费疫苗 -->
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <ItemsControl ItemsSource="{Binding FreeDoses}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="s:VaccinePlanView">
                                                            <Border Classes="vf-card" Classes.done="{Binding IsDone}"
                                                                    Classes.skipped="{Binding IsSkipped}"
                                                                    Classes.replaced="{Binding IsReplaced}"
                                                                    Classes.overdue="{Binding IsOverdue}"
                                                                    Classes.due="{Binding IsDue}"
                                                                    Classes.soon="{Binding IsSoon}"
                                                                    Classes.pending="{Binding IsPending}"
                                                                    PointerPressed="OnVaccineDoseClick">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="{Binding VaccineName}" FontSize="12" FontWeight="Medium"/>
                                                                    <TextBlock FontSize="10" Foreground="{StaticResource WeuiFg2Brush}">
                                                                        <Run Text="{Binding DoseLabel}"/>
                                                                        <Run Text=" · "/>
                                                                        <Run Text="{Binding RecommendedDateText, TargetNullValue='按门诊安排'}"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Disease}" FontSize="10" Foreground="{StaticResource WeuiFg2Brush}"/>
                                                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                                                        <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="10" Foreground="{StaticResource WeuiFg2Brush}" VerticalAlignment="Center"/>
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                                                    IsVisible="{Binding NotHandled}">
                                                                            <Button Classes="vf-mark" Content="已打" Click="OnVaccineMarkDone"/>
                                                                            <Button Classes="vf-skip" Content="跳过" Click="OnVaccineSkip"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding DoneTime}" FontSize="10" Foreground="#9EE6C1"
                                                                               IsVisible="{Binding DoneTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="暂无" FontSize="11" Foreground="{StaticResource WeuiFg3Brush}"
                                                           HorizontalAlignment="Center" IsVisible="{Binding !HasFree}"/>
                                            </StackPanel>

                                            <!-- 中：时间轴节点（连贯竖线 + 圆点 + 标签） -->
                                            <Panel Grid.Column="1" Width="60">
                                                <ctrl:TimelineAxisItem HorizontalAlignment="Center"
                                                                       LineBrush="#E5E7EB" LineWidth="2"
                                                                       DotSize="0" HalfSpacing="6"/>
                                                <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,0">
                                                    <Border Classes="vf-dot"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Medium" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DateText}" FontSize="9" Foreground="{StaticResource WeuiFg2Brush}" HorizontalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="{StaticResource WeuiFg3Brush}" HorizontalAlignment="Center">
                                                        <Run Text="{Binding HandledCount}"/>
                                                        <Run Text="/"/>
                                                        <Run Text="{Binding TotalCount}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Panel>

                                            <!-- 右：自费疫苗 -->
                                            <StackPanel Grid.Column="2" Spacing="4">
                                                <ItemsControl ItemsSource="{Binding PaidDoses}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="s:VaccinePlanView">
                                                            <Border Classes="vf-card" Classes.done="{Binding IsDone}"
                                                                    Classes.skipped="{Binding IsSkipped}"
                                                                    Classes.replaced="{Binding IsReplaced}"
                                                                    Classes.overdue="{Binding IsOverdue}"
                                                                    Classes.due="{Binding IsDue}"
                                                                    Classes.soon="{Binding IsSoon}"
                                                                    Classes.pending="{Binding IsPending}"
                                                                    PointerPressed="OnVaccineDoseClick">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="{Binding VaccineName}" FontSize="12" FontWeight="Medium"/>
                                                                    <TextBlock FontSize="10" Foreground="{StaticResource WeuiFg2Brush}">
                                                                        <Run Text="{Binding DoseLabel}"/>
                                                                        <Run Text=" · "/>
                                                                        <Run Text="{Binding RecommendedDateText, TargetNullValue='按门诊安排'}"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Disease}" FontSize="10" Foreground="{StaticResource WeuiFg2Brush}"/>
                                                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                                                        <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="10" Foreground="{StaticResource WeuiFg2Brush}" VerticalAlignment="Center"/>
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                                                    IsVisible="{Binding NotHandled}">
                                                                            <Button Classes="vf-mark" Content="已打" Click="OnVaccineMarkDone"/>
                                                                            <Button Classes="vf-skip" Content="跳过" Click="OnVaccineSkip"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding DoneTime}" FontSize="10" Foreground="#9EE6C1"
                                                                               IsVisible="{Binding DoneTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="暂无" FontSize="11" Foreground="{StaticResource WeuiFg3Brush}"
                                                           HorizontalAlignment="Center" IsVisible="{Binding !HasPaid}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.IsActivity}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="活动名称"/>
                                    <TextBox Classes="form-input" Text="{Binding ActivityForm.Name}" PlaceholderText="如：翻身练习、户外散步..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="活动类型"/>
                                    <Grid ColumnDefinitions="*,*,*">
                                        <Border Grid.Column="0" Classes="type-tab"
                                                Classes.active="{Binding ActivityForm.SelectedCategory, Converter={x:Static v:AppConverters.IsPlay}}"
                                                PointerPressed="OnCategoryPlay">
                                            <TextBlock Text="游戏"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="type-tab" Margin="8,0"
                                                Classes.active="{Binding ActivityForm.SelectedCategory, Converter={x:Static v:AppConverters.IsOutdoor}}"
                                                PointerPressed="OnCategoryOutdoor">
                                            <TextBlock Text="户外"/>
                                        </Border>
                                        <Border Grid.Column="2" Classes="type-tab"
                                                Classes.active="{Binding ActivityForm.SelectedCategory, Converter={x:Static v:AppConverters.IsExercise}}"
                                                PointerPressed="OnCategoryExercise">
                                            <TextBlock Text="运动"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="时长（分钟，选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding ActivityForm.DurationText}" PlaceholderText="0"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TimePicker SelectedTime="{Binding ActivityForm.TimeText, Converter={x:Static v:TimeTextToTimeSpanConverter.Instance}}"
                                                ClockIdentifier="24HourClock" FontSize="14" Background="#F5F5F5" CornerRadius="8" Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource WeuiRedBrush}" FontSize="13"
                                   Margin="0,4" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="16,12" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,1,0,0"
                        IsVisible="{Binding ActiveType, Converter={x:Static v:AppConverters.NotVaccine}}">
                    <Button Content="保存记录" Classes="weui-btn primary" HorizontalAlignment="Stretch"
                            Command="{Binding SaveCommand}"/>
                </Border>
            </Grid>
        </Border>
    </Panel>
</UserControl>
