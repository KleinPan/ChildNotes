<UserControl x:Class="ChildNotes.Views.AiNoteView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ChildNotes.ViewModels"
             d:DesignHeight="844"
             d:DesignWidth="390"
             x:DataType="vm:AiNoteViewModel"
             Background="Transparent"
             mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="TextBox.ai-input">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="MinHeight" Value="120" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <!--  模态遮罩  -->
        <Border Classes="modal-mask" />

        <!--
            底部抽屉：结构与 RecordSheetView 保持一致。
            MaxHeight 由 code-behind 根据软键盘状态动态调整，
            x:Name=SheetRoot 供 code-behind 访问。
        -->
        <Border x:Name="SheetRoot" MaxHeight="600" VerticalAlignment="Bottom"
                Background="{StaticResource WeuiBg2Brush}"
                CornerRadius="16,16,0,0">

            <Grid RowDefinitions="Auto,*,Auto">
                <!--  标题栏  -->
                <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock FontSize="17" FontWeight="Bold" Text="🤖 Ai 记" />
                            <TextBlock FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Text="用一句话记录，AI 帮你自动分类保存" />
                        </StackPanel>
                        <Button Grid.Column="1" Padding="8,2" Background="Transparent" BorderThickness="0"
                                Command="{Binding CancelCommand}"
                                Content="✕" FontSize="18" />
                    </Grid>
                </Border>

                <!--  可滚动内容区  -->
                <ScrollViewer x:Name="ContentScroll" Grid.Row="1" Padding="16,16" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <!--  输入框  -->
                        <TextBox VerticalContentAlignment="Top" Classes="ai-input" PlaceholderText="{Binding Placeholder}" Text="{Binding InputText}" />

                        <!--  示例提示  -->
                        <StackPanel IsVisible="{Binding !ShowResult}" Spacing="2">
                            <TextBlock FontSize="11" Foreground="{StaticResource WeuiFg2Brush}" Text="示例：" />
                            <TextBlock FontSize="11" Foreground="{StaticResource WeuiFg2Brush}" Text="• 14点30分喝了120ml奶" />
                            <TextBlock FontSize="11" Foreground="{StaticResource WeuiFg2Brush}" Text="• 换尿布 嘘嘘" />
                            <TextBlock FontSize="11" Foreground="{StaticResource WeuiFg2Brush}" Text="• 亲喂 左10分 右15分" />
                            <TextBlock FontSize="11" Foreground="{StaticResource WeuiFg2Brush}" Text="• 体温37.5度" />
                        </StackPanel>

                        <!--  错误提示  -->
                        <Border Padding="10,8" Background="#FFF0F0" CornerRadius="8" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock FontSize="12" Foreground="{StaticResource WeuiRedBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
                        </Border>

                        <!--  解析结果反馈  -->
                        <Border Padding="10,8" Background="#E8F9EF" CornerRadius="8" IsVisible="{Binding ShowResult}">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="13" FontWeight="Medium" Foreground="#06AD56" Text="✅ 已保存" />
                                <TextBlock FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Text="{Binding ResultSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!--  底部按钮区  -->
                <Border Grid.Row="2" Padding="16,12" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,1,0,0">
                    <Button MinHeight="40"
                            Classes="weui-btn primary"
                            Command="{Binding SaveCommand}"
                            Content="Ai记"
                            CornerRadius="24"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding !IsParsing}" />
                </Border>
            </Grid>
        </Border>

        <!--  Toast 浮层  -->
        <Border Margin="0,0,0,80" Padding="20,10" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Background="#CC000000" CornerRadius="8"
                IsVisible="{Binding ShowToast}">
            <TextBlock FontSize="13" Foreground="White" Text="{Binding ToastMessage}" />
        </Border>
    </Panel>
</UserControl>
