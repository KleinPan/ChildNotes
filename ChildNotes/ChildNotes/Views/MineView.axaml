<UserControl x:Class="ChildNotes.Views.MineView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ChildNotes.ViewModels"
             d:DesignHeight="844"
             d:DesignWidth="390"
             x:DataType="vm:MineViewModel"
             Background="{StaticResource WeuiBg0Brush}"
             mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <Border Margin="0,0,0,8" Padding="14,16" Background="{StaticResource WeuiBg2Brush}">
                <Grid ColumnDefinitions="Auto,*">
                    <!--  原版头像: 绿色渐变背景  -->
                    <Border Grid.Column="0" Width="56" Height="56"
                            Background="{StaticResource AvatarGradientBrush}"
                            CornerRadius="28">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" Foreground="White"
                                   Text="👤" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#1A1A1A" Text="{Binding NickName}" />
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" Text="{Binding RoleText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="section-title">
                <TextBlock Text="{DynamicResource Mine_Section_Baby}" />
            </Border>

            <Border Margin="12,4" Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}">
                <StackPanel>
                    <Grid Margin="14,12" PointerPressed="OnBabyManagerTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="👶" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_BabyManager}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource WeuiFg1Brush}"
                                   Text="{Binding BabyCountText}" />
                        <TextBlock Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnFamilyTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="👨‍👩‍👧" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_Family}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="section-title">
                <TextBlock Text="{DynamicResource Mine_Section_Tools}" />
            </Border>

            <Border Margin="12,4" Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}">
                <StackPanel>
                    <Grid Margin="14,12" PointerPressed="OnMembershipTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="24" Height="24"
                                Background="#FFB84D"
                                CornerRadius="6">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="White"
                                       Text="V" />
                        </Border>
                        <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="15"
                                   Text="{DynamicResource Mine_Membership}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource WeuiFg1Brush}"
                                   Text="{Binding MembershipStatusText}" />
                        <TextBlock Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnAiAnalysisTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="24" Height="24"
                                Background="{StaticResource WeuiBlueBrush}"
                                CornerRadius="6">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="White"
                                       Text="析" />
                        </Border>
                        <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="15"
                                   Text="{DynamicResource Mine_AiAnalysis}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource WeuiFg1Brush}"
                                   Text="{DynamicResource Mine_AiAnalysis_Sub}" />
                        <TextBlock Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnStatisticsTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="📊" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_Statistics}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnPointsTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="🎁" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_Points}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="section-title">
                <TextBlock Text="{DynamicResource Mine_Section_Settings}" />
            </Border>

            <Border Margin="12,4" Background="{StaticResource WeuiBg2Brush}" CornerRadius="{StaticResource WeuiCardRadius}">
                <StackPanel>
                    <Grid Margin="14,12" PointerPressed="OnLanguageSettingsTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="🌐" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15"
                                   Text="{DynamicResource Language_Title}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource WeuiFg1Brush}"
                                   Text="{Binding LanguageDisplayText}" />
                        <TextBlock Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnAiSettingsTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="🤖" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_AiSettings}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnReminderSettingsTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="🔔" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_ReminderSettings}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnSyncSettingsTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="☁️" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_SyncSettings}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"
                            IsVisible="{Binding IsDeveloperOptionsVisible}" />
                    <Grid Margin="14,12" PointerPressed="OnDeveloperOptionsTap"
                          IsVisible="{Binding IsDeveloperOptionsVisible}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="🔧" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_DeveloperOptions}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"
                            IsVisible="{Binding IsDeveloperOptionsVisible}"/>
                    <Grid Margin="14,12" PointerPressed="OnPrivacyPolicyTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="📜" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_PrivacyPolicy}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}" />
                    <Grid Margin="14,12" PointerPressed="OnUserAgreementTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="📑" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_UserAgreement}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"/>
                    <Grid Margin="14,12" PointerPressed="OnInAppMessageTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />

                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="📬" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_InAppMessage}" />
                        <Border Grid.Column="2" Height="16" MinWidth="16" Padding="4,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource WeuiRedBrush}"
                                CornerRadius="8"
                                IsVisible="{Binding HasUnreadMessages}">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="White"
                                       Text="{Binding UnreadMessageCount}" />
                        </Border>
                        <TextBlock Grid.Column="4" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"/>
                    <Grid Margin="14,12" PointerPressed="OnHelpTap">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="❓" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_Help}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="20"
                                   Foreground="{StaticResource WeuiFg2Brush}"
                                   Text="›" />
                    </Grid>
                    <Border Height="1" Margin="14,0" Background="{StaticResource WeuiFg3Brush}"/>
                    <Grid Margin="14,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="20"
                                   Text="ℹ️" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="15" Text="{DynamicResource Mine_About}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource WeuiFg1Brush}"
                                   Text="{Binding AppVersion}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  原版退出登录: 白底红字  -->
            <Button Margin="12,16" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Classes="weui-btn default"
                    Command="{Binding LogoutCommand}"
                    Content="{DynamicResource Mine_Logout}"
                    Foreground="{StaticResource WeuiRedBrush}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
