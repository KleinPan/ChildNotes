<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:v="using:ChildNotes.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.BabySetupView"
             x:DataType="vm:BabySetupViewModel">

    <!-- 对齐小程序 baby-setup: 渐变背景 + 居中卡片 -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Margin="20,30" MaxWidth="360">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#E8F9EF"/>
                    <GradientStop Offset="0.4" Color="#F5F5F5"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border Background="White" CornerRadius="12" Padding="20,30"
                    BoxShadow="0 4 20 0 #15000000">
                <StackPanel Spacing="16">

                    <!-- 头部引导 -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10" Spacing="6">
                        <TextBlock Text="🍼" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="欢迎使用成长记录" FontSize="19" FontWeight="Bold"
                                   Foreground="#222" HorizontalAlignment="Center"/>
                        <TextBlock Text="请先添加宝宝信息，再开始记录吧" FontSize="13"
                                   Foreground="{StaticResource WeuiFg1Brush}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 性别选择 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,6">
                        <TextBlock Text="性别" FontSize="15" Width="60" VerticalAlignment="Center" Foreground="#333"/>
                        <Button Content="👦 男宝" Classes="gender-btn"
                                Classes.active="{Binding Gender, Converter={x:Static v:AppConverters.IsBoy}}"
                                Click="OnBoyTap"/>
                        <Button Content="👧 女宝" Classes="gender-btn" Margin="10,0,0,0"
                                Classes.active="{Binding Gender, Converter={x:Static v:AppConverters.IsGirl}}"
                                Click="OnGirlTap"/>
                    </StackPanel>

                    <Border BorderBrush="#F0F0F0" BorderThickness="0,1"/>

                    <!-- 姓名 -->
                    <StackPanel Orientation="Horizontal" Height="48" VerticalAlignment="Center">
                        <TextBlock Text="姓名" FontSize="15" Width="60" VerticalAlignment="Center" Foreground="#333"/>
                        <TextBox Text="{Binding Name}" PlaceholderText="请输入宝宝姓名或小名" MaxLength="20"
                                 BorderThickness="0" Background="Transparent" FontSize="15"
                                 VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <Border BorderBrush="#F0F0F0" BorderThickness="0,1"/>

                    <!-- 出生日期 -->
                    <StackPanel Orientation="Horizontal" Height="48" VerticalAlignment="Center">
                        <TextBlock Text="生日" FontSize="15" Width="60" VerticalAlignment="Center" Foreground="#333"/>
                        <CalendarDatePicker SelectedDate="{Binding BirthDate}"
                                            PlaceholderText="请选择出生日期"
                                            HorizontalAlignment="Stretch" FontSize="15"/>
                    </StackPanel>

                    <Border BorderBrush="#F0F0F0" BorderThickness="0,1"/>

                    <!-- 错误提示 -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource WeuiRedBrush}" FontSize="13"
                               Margin="0,4"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- 保存按钮 -->
                    <Button Content="开始记录" Classes="weui-btn primary" CornerRadius="24"
                            Command="{Binding SaveCommand}" IsEnabled="{Binding !Saving}"
                            Margin="0,16,0,0" HorizontalAlignment="Stretch" MinHeight="48"/>

                    <!-- 跳过 -->
                    <Button Content="稍后再说" Background="Transparent" BorderThickness="0" CornerRadius="6"
                            Foreground="#BBBBBB" FontSize="14" Margin="0,4,0,0" MinHeight="40" Padding="20,8"
                            Command="{Binding SkipCommand}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </ScrollViewer>

    <UserControl.Styles>
        <Style Selector="Button.gender-btn">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.gender-btn.active">
            <Setter Property="Background" Value="#E8F9EF"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiGreenBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WeuiGreenBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.gender-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>
        <Style Selector="Button.gender-btn.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E8F9EF"/>
        </Style>
    </UserControl.Styles>
</UserControl>
