<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:v="using:ChildNotes.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.QuickRecordCardView"
             x:DataType="vm:QuickMenuViewModel"
             Background="Transparent">

    <UserControl.Styles>
        <Style Selector="Border.form-section">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="TextBlock.form-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style Selector="Border.type-tab">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Background" Value="{StaticResource WeuiBg1Brush}"/>
        </Style>
        <Style Selector="Border.type-tab.active">
            <Setter Property="Background" Value="{StaticResource WeuiGreenBrush}"/>
        </Style>
        <Style Selector="Border.type-tab TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource WeuiFg1Brush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.type-tab.active TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Border.type-card">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Background" Value="{StaticResource WeuiBg1Brush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Border.type-card.active">
            <Setter Property="Background" Value="#E8F9EF"/>
            <Setter Property="BorderBrush" Value="{StaticResource WeuiGreenBrush}"/>
        </Style>
        <Style Selector="TextBox.form-input">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- 遮罩：点击关闭卡片 -->
        <Border Background="#80000000" PointerPressed="OnMaskPressed"/>

        <!-- 居中卡片 -->
        <Border CornerRadius="16"
                Width="380"
                MaxWidth="380"
                MaxHeight="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BoxShadow="0 4 20 0 #33000000">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- 标题栏 -->
                <Border Grid.Row="0" Padding="18,14" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding CardTitle}" FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" FontSize="18" Padding="8,2"
                                Background="Transparent" BorderThickness="0"
                                Command="{Binding CloseCardCommand}"/>
                    </Grid>
                </Border>

                <!-- 表单内容 -->
                <ScrollViewer Grid.Row="1" Padding="18,16,18,8" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,8">

                        <!-- 喂奶 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsFeedConverter}}">
                            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,12">
                                <Border Grid.Column="0" Classes="type-tab"
                                        Classes.active="{Binding RecordSheet.FeedForm.FeedType, Converter={x:Static v:RecordSheetView.IsBottleConverter}}"
                                        PointerPressed="OnFeedBottle">
                                    <TextBlock Text="🍼 配方奶"/>
                                </Border>
                                <Border Grid.Column="1" Classes="type-tab" Margin="6,0"
                                        Classes.active="{Binding RecordSheet.FeedForm.FeedType, Converter={x:Static v:RecordSheetView.IsBreastConverter}}"
                                        PointerPressed="OnFeedBreast">
                                    <TextBlock Text="🤱 亲喂"/>
                                </Border>
                                <Border Grid.Column="2" Classes="type-tab"
                                        Classes.active="{Binding RecordSheet.FeedForm.FeedType, Converter={x:Static v:RecordSheetView.IsExpressedConverter}}"
                                        PointerPressed="OnFeedExpressed">
                                    <TextBlock Text="🍶 瓶喂母乳"/>
                                </Border>
                            </Grid>
                            <StackPanel IsVisible="{Binding RecordSheet.FeedForm.FeedType, Converter={x:Static v:RecordSheetView.IsBreastConverter}}">
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="← 左侧时长（分钟）"/>
                                        <TextBox Classes="form-input" Text="{Binding RecordSheet.FeedForm.LeftDurationText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="→ 右侧时长（分钟）"/>
                                        <TextBox Classes="form-input" Text="{Binding RecordSheet.FeedForm.RightDurationText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel IsVisible="{Binding RecordSheet.FeedForm.FeedType, Converter={x:Static v:RecordSheetView.IsNotBreastConverter}}">
                                <Border Classes="form-section">
                                    <StackPanel>
                                        <TextBlock Classes="form-label" Text="奶量（ml）"/>
                                        <TextBox Classes="form-input" Text="{Binding RecordSheet.FeedForm.AmountText}" PlaceholderText="请输入奶量"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.FeedForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 换尿布 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsDiaperConverter}}">
                            <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,12">
                                <Border Grid.Column="0" Classes="type-card"
                                        Classes.active="{Binding RecordSheet.DiaperForm.DiaperType, Converter={x:Static v:RecordSheetView.IsWetConverter}}"
                                        PointerPressed="OnDiaperWet">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💧" FontSize="22" HorizontalAlignment="Center"/>
                                        <TextBlock Text="嘘嘘" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="type-card" Margin="6,0"
                                        Classes.active="{Binding RecordSheet.DiaperForm.DiaperType, Converter={x:Static v:RecordSheetView.IsDirtyConverter}}"
                                        PointerPressed="OnDiaperDirty">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💩" FontSize="22" HorizontalAlignment="Center"/>
                                        <TextBlock Text="便便" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="type-card"
                                        Classes.active="{Binding RecordSheet.DiaperForm.DiaperType, Converter={x:Static v:RecordSheetView.IsBothConverter}}"
                                        PointerPressed="OnDiaperBoth">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💧💩" FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="都有" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Classes="type-card" Margin="6,0,0,0"
                                        Classes.active="{Binding RecordSheet.DiaperForm.DiaperType, Converter={x:Static v:RecordSheetView.IsDryConverter}}"
                                        PointerPressed="OnDiaperDry">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="✅" FontSize="22" HorizontalAlignment="Center"/>
                                        <TextBlock Text="干爽" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.DiaperForm.SelectedConsistency}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.DiaperForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 睡眠 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsSleepConverter}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="开始时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.SleepForm.StartTimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="结束时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.SleepForm.EndTimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 体温 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsTempConverter}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="体温（℃）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.TemperatureForm.TemperatureText}" PlaceholderText="输入体温"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section" Background="#FFF0F0" CornerRadius="8" Padding="10"
                                    IsVisible="{Binding RecordSheet.TemperatureForm.IsFeverWarning}">
                                <TextBlock Text="⚠️ 体温 ≥ 37.3℃，保存后将触发发烧追踪" FontSize="12" Foreground="{StaticResource WeuiRedBrush}"/>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.TemperatureForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.TemperatureForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 成长 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsGrowthConverter}}">
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
                                <Border Grid.Column="0" Background="#F9F9F9" CornerRadius="12" Padding="14" MinWidth="140">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📏" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="身高" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBox Text="{Binding RecordSheet.GrowthForm.HeightText}" PlaceholderText="0" Width="80" FontSize="22" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="8" Background="White"/>
                                            <TextBlock Text="cm" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="12" Padding="14" Margin="10,0,0,0" MinWidth="140">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⚖️" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="体重" FontSize="12" Foreground="{StaticResource WeuiFg1Brush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBox Text="{Binding RecordSheet.GrowthForm.WeightText}" PlaceholderText="0" Width="80" FontSize="22" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="8" Background="White"/>
                                            <TextBlock Text="kg" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.GrowthForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 补给用药 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsSupplementConverter}}">
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
                                <Border Grid.Column="0" Classes="type-tab"
                                        Classes.active="{Binding RecordSheet.SupplementForm.SuppType, Converter={x:Static v:RecordSheetView.IsMedicineConverter}}"
                                        PointerPressed="OnSuppMedicine">
                                    <TextBlock Text="💊 用药"/>
                                </Border>
                                <Border Grid.Column="1" Classes="type-tab" Margin="10,0,0,0"
                                        Classes.active="{Binding RecordSheet.SupplementForm.SuppType, Converter={x:Static v:RecordSheetView.IsNutritionConverter}}"
                                        PointerPressed="OnSuppNutrition">
                                    <TextBlock Text="🥗 营养"/>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="名称"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.SupplementForm.Name}" PlaceholderText="如：维生素D、退烧药..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="剂量（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.SupplementForm.Dose}" PlaceholderText="如：1滴、5ml..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.SupplementForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.SupplementForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 吸奶 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsPumpConverter}}">
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,10">
                                <Border Grid.Column="0" Background="#F9F9F9" CornerRadius="10" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="左侧时长（分钟）" FontSize="11" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,4"/>
                                        <TextBox Classes="form-input" Text="{Binding RecordSheet.PumpForm.LeftDurationText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="10" Padding="10,8" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="右侧时长（分钟）" FontSize="11" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,4"/>
                                        <TextBox Classes="form-input" Text="{Binding RecordSheet.PumpForm.RightDurationText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,10">
                                <Border Grid.Column="0" Background="#F9F9F9" CornerRadius="10" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="左侧奶量（ml）" FontSize="11" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,4"/>
                                        <TextBox Classes="form-input" Text="{Binding RecordSheet.PumpForm.LeftAmountText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="10" Padding="10,8" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="右侧奶量（ml）" FontSize="11" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,4"/>
                                        <TextBox Classes="form-input" Text="{Binding RecordSheet.PumpForm.RightAmountText}" PlaceholderText="0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="总奶量（ml，选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.PumpForm.TotalAmountText}" PlaceholderText="不填则自动计算"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.PumpForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.PumpForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 辅食 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:RecordSheetView.IsComplementaryConverter}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="食物名称"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.ComplementaryForm.FoodName}" PlaceholderText="如：南瓜泥、米粉..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="质地"/>
                                    <Grid ColumnDefinitions="*,*,*">
                                        <Border Grid.Column="0" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.ComplementaryForm.SelectedTexture, Converter={x:Static v:RecordSheetView.IsPureeConverter}}"
                                                PointerPressed="OnTexturePuree">
                                            <TextBlock Text="泥糊"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="type-tab" Margin="6,0"
                                                Classes.active="{Binding RecordSheet.ComplementaryForm.SelectedTexture, Converter={x:Static v:RecordSheetView.IsMashedConverter}}"
                                                PointerPressed="OnTextureMashed">
                                            <TextBlock Text="碎末"/>
                                        </Border>
                                        <Border Grid.Column="2" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.ComplementaryForm.SelectedTexture, Converter={x:Static v:RecordSheetView.IsLumpyConverter}}"
                                                PointerPressed="OnTextureLumpy">
                                            <TextBlock Text="小块"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="食量（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.ComplementaryForm.AmountText}" PlaceholderText="如：2勺、半碗..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="反应"/>
                                    <Grid ColumnDefinitions="*,*,*,*">
                                        <Border Grid.Column="0" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.ComplementaryForm.SelectedReaction, Converter={x:Static v:RecordSheetView.IsNoneReactionConverter}}"
                                                PointerPressed="OnReactionNone">
                                            <TextBlock Text="无"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="type-tab" Margin="4,0"
                                                Classes.active="{Binding RecordSheet.ComplementaryForm.SelectedReaction, Converter={x:Static v:RecordSheetView.IsAllergyConverter}}"
                                                PointerPressed="OnReactionAllergy">
                                            <TextBlock Text="过敏"/>
                                        </Border>
                                        <Border Grid.Column="2" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.ComplementaryForm.SelectedReaction, Converter={x:Static v:RecordSheetView.IsVomitReactionConverter}}"
                                                PointerPressed="OnReactionVomit">
                                            <TextBlock Text="呕吐"/>
                                        </Border>
                                        <Border Grid.Column="3" Classes="type-tab" Margin="4,0,0,0"
                                                Classes.active="{Binding RecordSheet.ComplementaryForm.SelectedReaction, Converter={x:Static v:RecordSheetView.IsDiarrheaReactionConverter}}"
                                                PointerPressed="OnReactionDiarrhea">
                                            <TextBlock Text="腹泻"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.ComplementaryForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.ComplementaryForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 妈妈饮食 -->
                        <StackPanel IsVisible="{Binding RecordSheet.ActiveType, Converter={x:Static v:QuickRecordCardView.IsMaternalFoodConverter}}">
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="餐次"/>
                                    <Grid ColumnDefinitions="*,*,*,*">
                                        <Border Grid.Column="0" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.MaternalFoodForm.SelectedMealType, Converter={x:Static v:QuickRecordCardView.IsBreakfastConverter}}"
                                                PointerPressed="OnMealBreakfast">
                                            <TextBlock Text="早餐"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="type-tab" Margin="4,0"
                                                Classes.active="{Binding RecordSheet.MaternalFoodForm.SelectedMealType, Converter={x:Static v:QuickRecordCardView.IsLunchConverter}}"
                                                PointerPressed="OnMealLunch">
                                            <TextBlock Text="午餐"/>
                                        </Border>
                                        <Border Grid.Column="2" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.MaternalFoodForm.SelectedMealType, Converter={x:Static v:QuickRecordCardView.IsDinnerConverter}}"
                                                PointerPressed="OnMealDinner">
                                            <TextBlock Text="晚餐"/>
                                        </Border>
                                        <Border Grid.Column="3" Classes="type-tab" Margin="4,0,0,0"
                                                Classes.active="{Binding RecordSheet.MaternalFoodForm.SelectedMealType, Converter={x:Static v:QuickRecordCardView.IsSnackConverter}}"
                                                PointerPressed="OnMealSnack">
                                            <TextBlock Text="加餐"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="食物（用顿号分隔多个）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.MaternalFoodForm.FoodsText}" PlaceholderText="如：米饭、青菜、鸡蛋..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="疑似过敏反应"/>
                                    <Grid ColumnDefinitions="*,*,*">
                                        <Border Grid.Column="0" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.MaternalFoodForm.SelectedSuspicionLevel, Converter={x:Static v:QuickRecordCardView.IsNoSuspicionConverter}}"
                                                PointerPressed="OnSuspicionNone">
                                            <TextBlock Text="无"/>
                                        </Border>
                                        <Border Grid.Column="1" Classes="type-tab" Margin="6,0"
                                                Classes.active="{Binding RecordSheet.MaternalFoodForm.SelectedSuspicionLevel, Converter={x:Static v:QuickRecordCardView.IsMildSuspicionConverter}}"
                                                PointerPressed="OnSuspicionMild">
                                            <TextBlock Text="轻微"/>
                                        </Border>
                                        <Border Grid.Column="2" Classes="type-tab"
                                                Classes.active="{Binding RecordSheet.MaternalFoodForm.SelectedSuspicionLevel, Converter={x:Static v:QuickRecordCardView.IsHighSuspicionConverter}}"
                                                PointerPressed="OnSuspicionHigh">
                                            <TextBlock Text="明显"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="备注（选填）"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.MaternalFoodForm.Note}" PlaceholderText="补充说明..."/>
                                </StackPanel>
                            </Border>
                            <Border Classes="form-section">
                                <StackPanel>
                                    <TextBlock Classes="form-label" Text="记录时间"/>
                                    <TextBox Classes="form-input" Text="{Binding RecordSheet.MaternalFoodForm.TimeText}" PlaceholderText="HH:mm"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding RecordSheet.ErrorMessage}" Foreground="{StaticResource WeuiRedBrush}" FontSize="13"
                                   Margin="0,4" IsVisible="{Binding RecordSheet.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 保存按钮 -->
                <Border Grid.Row="2" Padding="18,14" BorderBrush="{StaticResource WeuiFg3Brush}" BorderThickness="0,1,0,0">
                    <Button Content="保存记录" Classes="weui-btn primary" HorizontalAlignment="Stretch"
                            Command="{Binding RecordSheet.SaveCommand}"/>
                </Border>
            </Grid>
        </Border>
    </Panel>
</UserControl>
