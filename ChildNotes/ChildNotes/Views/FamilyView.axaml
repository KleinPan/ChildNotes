<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChildNotes.ViewModels"
             xmlns:shared="using:ChildNotes.Shared.Dtos"
             xmlns:sharedConst="using:ChildNotes.Shared.Constants"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="390" d:DesignHeight="844"
             x:Class="ChildNotes.Views.FamilyView"
             x:DataType="vm:FamilyViewModel"
             Background="{StaticResource WeuiBg0Brush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 顶栏 -->
        <Border Grid.Row="0" Classes="nav-bar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Classes="nav-back" Command="{Binding BackCommand}"/>
                <TextBlock Grid.Column="1" Classes="nav-title" Text="{DynamicResource Family_Title}"/>
                <Button Grid.Column="2" Content="{DynamicResource Family_Refresh}" Classes="weui-btn mini"
                        Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 加入家庭按钮 -->
                <Button Content="{DynamicResource Family_JoinById}" Classes="weui-btn primary"
                        Margin="12,12" HorizontalAlignment="Stretch"
                        Click="OnJoinTap"/>

                <!-- 加载中 / 空态 -->
                <StackPanel IsVisible="{Binding !HasData}" Margin="0,40">
                    <TextBlock Text="{Binding EmptyHint}" FontSize="14"
                               Foreground="{StaticResource WeuiFg1Brush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- 家庭列表 -->
                <ItemsControl ItemsSource="{Binding Families}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="shared:BabyFamilyDto">
                            <Border Background="{StaticResource WeuiBg2Brush}"
                                    CornerRadius="{StaticResource WeuiCardRadius}" Margin="12,4">
                                <StackPanel>
                                    <!-- 家庭标题 -->
                                    <Grid Margin="14,12" ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="👶" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding BabyName}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="{DynamicResource Family_MyRole}" Classes="weui-btn mini"
                                                Click="OnEditRoleTap" Tag="{Binding}"/>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource WeuiFg3Brush}" Margin="14,0"/>

                                    <!-- 宝宝 ID 行：宝宝主人可复制给家人用于加入家庭 -->
                                    <Grid Margin="14,10" ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="{DynamicResource Family_BabyId}" FontSize="12"
                                                   Foreground="{StaticResource WeuiFg1Brush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding BabyId}" FontSize="12"
                                                   Foreground="{StaticResource WeuiFg2Brush}"
                                                   FontFamily="Consolas,Menlo,monospace"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="2" Content="{DynamicResource Common_Copy}" Classes="weui-btn mini"
                                                Click="OnCopyBabyIdTap" Tag="{Binding BabyId}"/>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource WeuiFg3Brush}" Margin="14,0"/>

                                    <!-- 成员列表 -->
                                    <ItemsControl ItemsSource="{Binding Members}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="shared:BabyMemberDto">
                                                <Grid Margin="14,10" ColumnDefinitions="Auto,*,Auto">
                                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                            Background="{StaticResource AvatarGradientBrush}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="👤" FontSize="18" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding NickName}" FontSize="14" FontWeight="Medium"/>
                                                            <TextBlock Text="{DynamicResource Family_Me}" FontSize="12" Foreground="{StaticResource WeuiGreenBrush}"
                                                                       IsVisible="{Binding Mine}" Margin="2,0,0,0"/>
                                                            <Border Background="{StaticResource WeuiGreenBrush}" CornerRadius="4"
                                                                    Padding="4,1" Margin="6,0,0,0" IsVisible="{Binding Owner}">
                                                                <TextBlock Text="{DynamicResource Family_Owner}" FontSize="10" Foreground="White"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding RoleName}" FontSize="12"
                                                                   Foreground="{StaticResource WeuiFg1Brush}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="24"/>

            </StackPanel>
        </ScrollViewer>

        <!-- 加入家庭弹窗 -->
        <Border Grid.RowSpan="2" Background="#88000000" IsVisible="{Binding IsJoinOpen}">
            <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="12"
                    Width="320" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Family_JoinFamily}" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="{DynamicResource Family_BabyId}" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding JoinBabyId}" PlaceholderText="{DynamicResource Family_JoinPlaceholder}" Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource Family_SelectRole}" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding RoleOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sharedConst:RoleOption">
                                <Button Content="{Binding Name}" Classes="weui-btn mini" Margin="0,0,6,6"
                                        Click="OnSelectJoinRoleTap" Tag="{Binding Code}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding JoinRoleCode, Converter={x:Static vm:RoleNameConverter.Instance}}"
                               FontSize="12" Foreground="{StaticResource WeuiGreenBrush}" Margin="0,4,0,10"/>
                    <TextBlock Text="{Binding JoinError}" FontSize="12" Foreground="{StaticResource WeuiRedBrush}"
                               Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <Button Grid.Column="0" Content="{DynamicResource Common_Cancel}" Classes="weui-btn default" Command="{Binding CloseJoinCommand}"/>
                        <Button Grid.Column="2" Content="{DynamicResource Family_JoinNow}" Classes="weui-btn primary" Command="{Binding ConfirmJoinCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- 修改角色弹窗 -->
        <Border Grid.RowSpan="2" Background="#88000000" IsVisible="{Binding IsRoleEditorOpen}">
            <Border Background="{StaticResource WeuiBg2Brush}" CornerRadius="12"
                    Width="320" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding RoleEditorTitle}" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="{DynamicResource Family_SelectRole}" FontSize="13" Foreground="{StaticResource WeuiFg1Brush}" Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding RoleOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sharedConst:RoleOption">
                                <Button Content="{Binding Name}" Classes="weui-btn mini" Margin="0,0,6,6"
                                        Click="OnSelectEditingRoleTap" Tag="{Binding Code}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding EditingRoleCode, Converter={x:Static vm:RoleNameConverter.Instance}}"
                               FontSize="12" Foreground="{StaticResource WeuiGreenBrush}" Margin="0,4,0,16"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <Button Grid.Column="0" Content="{DynamicResource Common_Cancel}" Classes="weui-btn default" Command="{Binding CloseRoleEditorCommand}"/>
                        <Button Grid.Column="2" Content="{DynamicResource Common_Save}" Classes="weui-btn primary" Command="{Binding ConfirmRoleCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Toast -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,80"
                Background="#CC000000" CornerRadius="8" Padding="20,10" IsVisible="{Binding ShowToast}">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
