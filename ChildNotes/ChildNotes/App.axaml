<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ChildNotes"
             xmlns:semi="https://irihi.tech/semi"
             x:Class="ChildNotes.App"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ChildNotes/Styles/WeUIColors.axaml"/>
                <ResourceInclude Source="avares://ChildNotes/Styles/AppIcons.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <semi:SemiTheme Locale="zh-CN"/>
        <StyleInclude Source="avares://ChildNotes/Styles/WeUIStyles.axaml"/>
    </Application.Styles>
</Application>
