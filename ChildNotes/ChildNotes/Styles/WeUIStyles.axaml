<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ChildNotes.Styles.WeUIStyles">

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}" />
    </Style>

    <!-- 去掉所有 Button 在按下/悬停时出现的阴影（Fluent 主题默认会有 elevation 投影） -->
    <Style Selector="Button /template/ ContentPresenter">
        <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
    </Style>

    <Style Selector="Border.weui-card">
        <Setter Property="Background" Value="{StaticResource WeuiBg2Brush}" />
        <Setter Property="CornerRadius" Value="{StaticResource WeuiCardRadius}" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="12,8" />
        <!-- 原版阴影: 0 2rpx 16rpx rgba(0,0,0,0.04) -->
        <Setter Property="BoxShadow" Value="0 1 8 0 #0A000000" />
    </Style>

    <Style Selector="Border.weui-cell">
        <Setter Property="Background" Value="{StaticResource WeuiBg2Brush}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="CornerRadius" Value="{StaticResource WeuiCardRadius}" />
    </Style>

    <!-- 模态遮罩：统一各弹层/对话框的半透明黑色背景（50% black） -->
    <Style Selector="Border.modal-mask">
        <Setter Property="Background" Value="#80000000" />
    </Style>

    <!-- 注：Border.mini-card / Border.quick-action-bg / Border.chip(.active) 原 Style 已删除，
         经全项目 grep 验证从未被任何 axaml 引用（HomeView/StatisticsView/RecordSheetView 均自定义了局部样式）。
         若后续需统一这些样式，应在 View 内显式声明 Classes，避免死代码堆积。 -->

    <!-- 按钮交互反馈（Avalonia 12 规范）：Transitions + :pressed 伪类 -->
    <!-- 必须设置 RenderTransform="none" 初始值，否则首次过渡从 null 跳变 -->
    <Style Selector="Button.weui-btn">
        <Setter Property="CornerRadius" Value="{StaticResource WeuiBtnRadius}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="RenderTransform" Value="none"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform"
                                               Duration="0:0:0.08"
                                               Easing="QuadraticEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.weui-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.97)"/>
    </Style>

    <Style Selector="Button.weui-btn.primary">
        <Setter Property="Background" Value="{StaticResource WeuiGreenBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.weui-btn.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#06AD56" />
    </Style>

    <Style Selector="Button.weui-btn.warn">
        <Setter Property="Background" Value="{StaticResource WeuiRedBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.weui-btn.default">
        <Setter Property="Background" Value="{StaticResource WeuiBg2Brush}" />
        <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WeuiFg3Brush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.weui-btn.mini">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <Style Selector="Border.tab-bar">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#F0F0F0" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <!-- 原版阴影: 0 -2rpx 12rpx rgba(0,0,0,0.04) -->
        <Setter Property="BoxShadow" Value="0 -1 6 0 #0A000000" />
    </Style>

    <Style Selector="Button.tab-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="0,6" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <!-- 原版 tabBar 高度 100rpx ≈ 50px -->
        <Setter Property="MinHeight" Value="50" />
        <!-- Tab 交互反馈：Transitions + :pressed -->
        <Setter Property="RenderTransform" Value="none"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform"
                                               Duration="0:0:0.1"
                                               Easing="QuadraticEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.tab-item:pressed">
        <Setter Property="RenderTransform" Value="scale(0.9)"/>
    </Style>
    <Style Selector="Button.tab-item PathIcon">
        <Setter Property="Foreground" Value="#999999" />
    </Style>
    <Style Selector="Button.tab-item TextBlock.tab-text">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="#999999" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab-item.active PathIcon">
        <Setter Property="Foreground" Value="{StaticResource WeuiGreenBrush}" />
    </Style>
    <Style Selector="Button.tab-item.active TextBlock.tab-text">
        <Setter Property="Foreground" Value="{StaticResource WeuiGreenBrush}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- 注：原 Border.chip / Border.chip.active / Border.chip TextBlock 系列 Style 已删除，
         全项目 grep 验证从未引用（StatisticsView/RecordSheetView 各自定义 stat-chip/abn-chip 局部样式）。 -->

    <Style Selector="Border.section-title">
        <Setter Property="Margin" Value="16,12,16,4" />
    </Style>
    <Style Selector="Border.section-title TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}" />
    </Style>

    <!-- 统一顶栏（方案 C） -->
    <Style Selector="Border.nav-bar">
        <Setter Property="Background" Value="{StaticResource WeuiBg2Brush}"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="BorderBrush" Value="{StaticResource WeuiFg3Brush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style Selector="Border.nav-bar TextBlock.nav-title">
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 统一左上角返回按钮 -->
    <Style Selector="Button.nav-back">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Content" Value="‹"/>
        <Setter Property="MinWidth" Value="40"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>
    <Style Selector="Button.nav-back:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource WeuiBgColorActiveBrush}"/>
    </Style>
    <Style Selector="Button.nav-back:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource WeuiSeparatorBrush}"/>
    </Style>

    <!-- 纯图标按钮（顶栏操作图标，如扫把/设置） -->
    <Style Selector="Button.icon-only">
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Foreground" Value="{StaticResource WeuiFg0Brush}"/>
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>
    <Style Selector="Button.icon-only:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource WeuiBgColorActiveBrush}"/>
    </Style>
    <Style Selector="Button.icon-only:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource WeuiSeparatorBrush}"/>
    </Style>
</Styles>
