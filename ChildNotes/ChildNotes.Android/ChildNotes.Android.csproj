<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-android</TargetFramework>
    <!-- .NET 10 for Android 最低支持 API 24（Android 7.0），设为 23 会触发 XA1022 警告 -->
    <SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ApplicationId>com.CompanyName.ChildNotes</ApplicationId>
    <AndroidPackageFormat>apk</AndroidPackageFormat>
    <AndroidEnableProfiledAot>false</AndroidEnableProfiledAot>
    <!-- .NET 10 Android SDK 在 Release 下默认启用 RunAOTCompilation，但要求 PublishTrimmed=true。
         本项目未启用 trimming，故显式关闭 AOT，避免 XA1030 错误。 -->
    <RunAOTCompilation>false</RunAOTCompilation>

    <!-- ★ Android 版本号：强制覆盖以确保 versionName 不含 SemVer 后缀
         问题背景：.NET SDK 在 Debug 构建时会自动给 Version 追加源版本控制后缀
         （如 0.0.0 变成 0.0.0+53...），Android 不支持这种格式，会导致安装失败。
         解决方案：在此处无条件覆盖 ApplicationDisplayVersion，确保始终是纯净三段版本号。
         - Debug/本地构建：固定显示 0.0.0
         - CI Release 构建：通过 -p:ApplicationDisplayVersion=x.y.z 参数覆盖（release.yml 已配置） -->
    <ApplicationDisplayVersion>0.0.0</ApplicationDisplayVersion>
  </PropertyGroup>

  <ItemGroup>
    <AndroidResource Include="Icon.png">
      <Link>Resources\drawable\Icon.png</Link>
    </AndroidResource>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Android" />
    <!-- AndroidX.Core：用于 WindowInsetsCompat.Type.ime() 获取精确键盘高度，
         替代旧式 ViewTreeObserver screenHeight-rectBottom 计算（后者在部分设备上偏小导致间隙） -->
    <PackageReference Include="Xamarin.AndroidX.Core" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ChildNotes\ChildNotes.csproj" />
  </ItemGroup>
</Project>
